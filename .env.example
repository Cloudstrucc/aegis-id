NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Subscription capture is file-backed for the free-tier demo.
SUBSCRIPTION_STORE_PATH=data/subscriptions.json
SUBSCRIBER_WORKSPACE_STORE_PATH=data/subscriber-workspaces.json
TRANSACTION_STORE_PATH=data/transactions.json
AUDIT_STORE_PATH=data/audit-events.json

# Microsoft Entra Verified ID adapter.
# Use mock for local UI/demo. Use live after app registration and Verified ID tenant setup.
VID_MODE=mock
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
VID_CLIENT_NAME=Cloudstrucc Aegis ID
VID_AUTHORITY_DID=
VID_MANIFEST_URL=
VID_CREDENTIAL_TYPE=CloudstruccEmployeeCredential
VID_CALLBACK_API_KEY=

# Aries lab admin endpoints. Keep these on localhost unless explicitly tunneling for a lab.
ARIES_ISSUER_ADMIN_URL=http://localhost:4011
ARIES_VERIFIER_ADMIN_URL=http://localhost:5011
ARIES_MEDIATOR_ADMIN_URL=http://localhost:3011
