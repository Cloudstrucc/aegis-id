# Vanguard Cloud Services - Aegis ID environment template.
# Copy to .env for production, .env.local for localhost, .env.dev for dev Azure, or .env.qa for QA Azure.

# Unique per runtime: use development for localhost and production for Azure App Service.
NODE_ENV=development

# Unique for local only. Azure App Service supplies its own listener port.
PORT=3000

# Unique per deployment: public URL used in QR codes, callbacks, deep links, and passkey origin checks.
PUBLIC_BASE_URL=http://localhost:3000
APP_PUBLIC_BASE_URL=http://localhost:3000

# Unique per Azure deployment: tenant/subscription/resource group/App Service name used by deploy scripts.
AZURE_TENANT_ID=24a46daa-7b87-4566-9eea-281326a1b75c
AZURE_SUBSCRIPTION_ID=7719c366-5f64-439a-a6c6-65067d5a97e4
AZURE_RESOURCE_GROUP=rg-vanguard-aegis-id
AZURE_WEBAPP_NAME=vanguard-aegis-id-65067d
WEBSITE_NODE_DEFAULT_VERSION=~20

# Unique per deployment: optional public tester download links shown on the home page.
IOS_TESTFLIGHT_PUBLIC_URL=
ANDROID_TESTING_URL=
BUSINESS_EXPENSES_APP_URL=http://localhost:4300

# Unique per deployment: use /home/data/... on Azure App Service, and data/... locally.
USER_STORE_PATH=data/users.json
SUBSCRIPTION_STORE_PATH=data/subscriptions.json
SUBSCRIBER_WORKSPACE_STORE_PATH=data/subscriber-workspaces.json
TRANSACTION_STORE_PATH=data/transactions.json
ISSUER_ORG_STORE_PATH=data/issuer-organizations.json
ORG_ADMIN_STORE_PATH=data/org-admin.json
ORG_ADMIN_EVENT_STORE_PATH=data/org-admin-events.json
OIDC_WALLET_SESSION_STORE_PATH=data/oidc-wallet-sessions.json
OIDC_CODE_STORE_PATH=data/oidc-codes.json
WALLET_CHALLENGE_STORE_PATH=data/wallet-challenges.json
WALLET_PASSKEY_STORE_PATH=data/wallet-passkeys.json
AUDIT_STORE_PATH=data/audit-events.json
CONNECTED_APP_STORE_PATH=data/connected-apps.json
CONNECTED_APP_LOG_STORE_PATH=data/connected-app-logs.json
CONNECTED_APP_OAUTH_CODE_STORE_PATH=data/connected-app-oauth-codes.json
CONNECTED_APP_SIGNING_KEY_STORE_PATH=data/connected-app-signing-keys.json
CONNECTED_APP_UPSTREAM_STATE_STORE_PATH=data/connected-app-upstream-states.json

# Unique per deployment and secret: leave blank in templates; set directly in Azure or local private env files.
SESSION_SECRET=
CONNECTED_APP_SECRET_ENCRYPTION_KEY=

# Unique per deployment: passkey/WebAuthn RP ID and origin must match the host users open in their browser.
DEFAULT_MFA_METHOD=email
PASSKEY_RP_NAME=Vanguard Cloud Services - Aegis ID
PASSKEY_RP_ID=localhost
PASSKEY_ORIGIN=http://localhost:3000

# Unique per mobile app signing profile: used to publish iOS/Android associated-domain metadata.
IOS_APP_TEAM_ID=GL46AP73ZQ
IOS_APP_BUNDLE_ID=ca.vanguardcs.aegisid.wallet
# Optional comma-separated override. Leave blank to publish the default prod/dev/QA wallet bundle IDs.
IOS_APP_BUNDLE_IDS=ca.vanguardcs.aegisid.wallet,ca.vanguardcs.aegisid.wallet.dev,ca.vanguardcs.aegisid.wallet.qa
ANDROID_APP_PACKAGE_NAME=ca.vanguardcs.aegisid.wallet
ANDROID_SHA256_CERT_FINGERPRINTS=

# Unique per deployment: use mock locally, live on Azure once Entra Verified ID is configured.
VID_MODE=mock
VID_CLIENT_NAME=Vanguard Cloud Services - Aegis ID
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
VID_AUTHORITY_DID=
VID_MANIFEST_URL=
VID_CREDENTIAL_TYPE=VerifiedEmployee
VID_CALLBACK_API_KEY=

# Unique per lab deployment: keep localhost for local Docker, or use hosted ACA-Py admin endpoints for Azure lab agents.
ARIES_HOLDER_ADMIN_URL=http://localhost:6011
ARIES_ISSUER_ADMIN_URL=http://localhost:4011
ARIES_VERIFIER_ADMIN_URL=http://localhost:5011
ARIES_MEDIATOR_ADMIN_URL=http://localhost:3011
ARIES_ADMIN_API_KEY=
ARIES_HOLDER_ADMIN_API_KEY=
ARIES_ISSUER_ADMIN_API_KEY=
ARIES_VERIFIER_ADMIN_API_KEY=
ARIES_MEDIATOR_ADMIN_API_KEY=

# Unique per deployment: built-in OIDC + wallet challenge demo metadata and callback behavior.
OIDC_WALLET_DEMO_MODE=mock
OIDC_WALLET_ISSUER=https://mock-idp.vanguardcs.local
OIDC_WALLET_PUBLIC_BASE_URL=
OIDC_WALLET_AUTHORIZATION_ENDPOINT=/demo/oidc-wallet/mock-authorize
OIDC_WALLET_CLIENT_ID=vanguard-aegis-wallet-gated-app
OIDC_WALLET_SCOPE=openid profile email
OIDC_WALLET_SESSION_TTL_SECONDS=900

# Optional per deployment: enable Aegis as an OIDC broker with Entra ID as an upstream workforce IdP.
# Keep local unless this Aegis host has an Entra app registration and a public HTTPS callback.
CONNECTED_APP_UPSTREAM_IDP_MODE=local
CONNECTED_APP_UPSTREAM_ENTRA_TENANT_ID=
CONNECTED_APP_UPSTREAM_ENTRA_CLIENT_ID=
CONNECTED_APP_UPSTREAM_ENTRA_CLIENT_SECRET=
CONNECTED_APP_UPSTREAM_ENTRA_REDIRECT_URI=
CONNECTED_APP_UPSTREAM_ENTRA_SCOPES=openid profile email
CONNECTED_APP_UPSTREAM_ENTRA_ISSUER=
CONNECTED_APP_UPSTREAM_ENTRA_AUTHORIZATION_ENDPOINT=
CONNECTED_APP_UPSTREAM_ENTRA_TOKEN_ENDPOINT=
CONNECTED_APP_UPSTREAM_ENTRA_JWKS_URI=

# Unique per public Azure deployment: DID:web issuer endpoint support for Entra Verified ID custom issuer/domain binding.
# Localhost cannot satisfy public linked-domain validation; use the deployed App Service hostname or a custom domain.
AEGIS_DID_WEB_ENABLED=false
AEGIS_DID_WEB_DOMAIN=
AEGIS_DID_WEB_ORIGIN=
AEGIS_DID_WEB_ID=
AEGIS_DID_WEB_DID_DOCUMENT_URL=
AEGIS_DID_WEB_CONFIGURATION_URL=
AEGIS_DID_WEB_KEY_NAME=aegis-did-web-signing
AEGIS_DID_WEB_KEY_ALG=ES256
AEGIS_DID_WEB_KEY_CURVE=P-256
AEGIS_DID_WEB_KEYVAULT_URL=
AEGIS_DID_WEB_KEYVAULT_KEY_ID=
AEGIS_DID_WEB_CACHE_TTL_SECONDS=300
AEGIS_DID_WEB_CREDENTIAL_TTL_DAYS=365

# Optional tenant profile override example for VanguardCS deployments.
TENANT_VANGUARDCS_AEGIS_DID_WEB_ENABLED=true
TENANT_VANGUARDCS_AEGIS_DID_WEB_DOMAIN=vanguard-aegis-id-0e75d1.azurewebsites.net
TENANT_VANGUARDCS_AEGIS_DID_WEB_ORIGIN=https://vanguard-aegis-id-0e75d1.azurewebsites.net
TENANT_VANGUARDCS_AEGIS_DID_WEB_ID=did:web:vanguard-aegis-id-0e75d1.azurewebsites.net
TENANT_VANGUARDCS_AEGIS_DID_WEB_DID_DOCUMENT_URL=https://vanguard-aegis-id-0e75d1.azurewebsites.net/.well-known/did.json
TENANT_VANGUARDCS_AEGIS_DID_WEB_CONFIGURATION_URL=https://vanguard-aegis-id-0e75d1.azurewebsites.net/.well-known/did-configuration.json
TENANT_VANGUARDCS_AEGIS_DID_WEB_KEY_NAME=aegis-did-web-signing
TENANT_VANGUARDCS_AEGIS_DID_WEB_KEY_ALG=ES256
TENANT_VANGUARDCS_AEGIS_DID_WEB_KEY_CURVE=P-256
TENANT_VANGUARDCS_AEGIS_DID_WEB_KEYVAULT_URL=https://kv-aegis-0e75d1.vault.azure.net/
TENANT_VANGUARDCS_AEGIS_DID_WEB_KEYVAULT_KEY_ID=https://kv-aegis-0e75d1.vault.azure.net/keys/aegis-did-web-signing
TENANT_VANGUARDCS_AEGIS_DID_WEB_CACHE_TTL_SECONDS=300
TENANT_VANGUARDCS_AEGIS_DID_WEB_CREDENTIAL_TTL_DAYS=365

# Optional tenant profile override example for VanguardCS Connected Apps upstream federation.
TENANT_VANGUARDCS_CONNECTED_APP_STORE_PATH=/home/data/aegis-id/vanguardcs/prod/connected-apps.json
TENANT_VANGUARDCS_CONNECTED_APP_LOG_STORE_PATH=/home/data/aegis-id/vanguardcs/prod/connected-app-logs.json
TENANT_VANGUARDCS_CONNECTED_APP_OAUTH_CODE_STORE_PATH=/home/data/aegis-id/vanguardcs/prod/connected-app-oauth-codes.json
TENANT_VANGUARDCS_CONNECTED_APP_SIGNING_KEY_STORE_PATH=/home/data/aegis-id/vanguardcs/prod/connected-app-signing-keys.json
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_STATE_STORE_PATH=/home/data/aegis-id/vanguardcs/prod/connected-app-upstream-states.json
TENANT_VANGUARDCS_CONNECTED_APP_SECRET_ENCRYPTION_KEY=
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_IDP_MODE=local
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_TENANT_ID=6b4b0578-e6a2-4693-8f4c-af55cb10de87
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_CLIENT_ID=d67a6415-1033-40e1-85a1-87692c73aea9
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_CLIENT_SECRET=
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_REDIRECT_URI=https://vanguard-aegis-id-0e75d1.azurewebsites.net/oauth2/upstream/entra/callback
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_SCOPES=openid profile email
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_ISSUER=https://login.microsoftonline.com/6b4b0578-e6a2-4693-8f4c-af55cb10de87/v2.0
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_AUTHORIZATION_ENDPOINT=https://login.microsoftonline.com/6b4b0578-e6a2-4693-8f4c-af55cb10de87/oauth2/v2.0/authorize
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_TOKEN_ENDPOINT=https://login.microsoftonline.com/6b4b0578-e6a2-4693-8f4c-af55cb10de87/oauth2/v2.0/token
TENANT_VANGUARDCS_CONNECTED_APP_UPSTREAM_ENTRA_JWKS_URI=https://login.microsoftonline.com/6b4b0578-e6a2-4693-8f4c-af55cb10de87/discovery/v2.0/keys
