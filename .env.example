NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Local file-backed stores for the free-tier demo.
USER_STORE_PATH=data/users.json
SUBSCRIPTION_STORE_PATH=data/subscriptions.json
SUBSCRIBER_WORKSPACE_STORE_PATH=data/subscriber-workspaces.json
TRANSACTION_STORE_PATH=data/transactions.json
ISSUER_ORG_STORE_PATH=data/issuer-organizations.json
ORG_ADMIN_STORE_PATH=data/org-admin.json
ORG_ADMIN_EVENT_STORE_PATH=data/org-admin-events.json
OIDC_WALLET_SESSION_STORE_PATH=data/oidc-wallet-sessions.json
AUDIT_STORE_PATH=data/audit-events.json

# Passport session and passkey/WebAuthn settings.
# Use a strong generated secret in Azure App Service.
SESSION_SECRET=change-me-use-a-strong-random-secret
DEFAULT_MFA_METHOD=email
PASSKEY_RP_NAME=Vanguard Cloud Services - Aegis ID
PASSKEY_RP_ID=
PASSKEY_ORIGIN=

# Microsoft Entra Verified ID adapter.
# Use mock for local UI/demo. Use live after app registration and Verified ID tenant setup.
VID_MODE=mock
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
VID_CLIENT_NAME=Vanguard Cloud Services - Aegis ID
VID_AUTHORITY_DID=
VID_MANIFEST_URL=
VID_CREDENTIAL_TYPE=VanguardEmployeeCredential
VID_CALLBACK_API_KEY=

# Aries lab admin endpoints. Keep these on localhost unless explicitly tunneling for a lab.
ARIES_ISSUER_ADMIN_URL=http://localhost:4011
ARIES_VERIFIER_ADMIN_URL=http://localhost:5011
ARIES_MEDIATOR_ADMIN_URL=http://localhost:3011

# OIDC + wallet challenge example app.
# Mock mode uses the local /demo/oidc-wallet/mock-authorize page.
OIDC_WALLET_DEMO_MODE=mock
OIDC_WALLET_ISSUER=https://mock-idp.vanguardcs.local
OIDC_WALLET_PUBLIC_BASE_URL=
OIDC_WALLET_AUTHORIZATION_ENDPOINT=/demo/oidc-wallet/mock-authorize
OIDC_WALLET_CLIENT_ID=vanguard-aegis-wallet-gated-app
OIDC_WALLET_SCOPE=openid profile email
OIDC_WALLET_SESSION_TTL_SECONDS=900
