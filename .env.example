# Vanguard Cloud Services - Aegis ID environment template.
# Copy to .env for production, .env.local for localhost, .env.dev for dev Azure, or .env.qa for QA Azure.

# Unique per runtime: use development for localhost and production for Azure App Service.
NODE_ENV=development

# Unique for local only. Azure App Service supplies its own listener port.
PORT=3000

# Unique per deployment: public URL used in QR codes, callbacks, deep links, and passkey origin checks.
PUBLIC_BASE_URL=http://localhost:3000
APP_PUBLIC_BASE_URL=http://localhost:3000

# Unique per Azure deployment: tenant/subscription/resource group/App Service name used by deploy scripts.
AZURE_TENANT_ID=24a46daa-7b87-4566-9eea-281326a1b75c
AZURE_SUBSCRIPTION_ID=7719c366-5f64-439a-a6c6-65067d5a97e4
AZURE_RESOURCE_GROUP=rg-vanguard-aegis-id
AZURE_WEBAPP_NAME=vanguard-aegis-id-65067d
WEBSITE_NODE_DEFAULT_VERSION=~20

# Unique per deployment: optional public tester download links shown on the home page.
IOS_TESTFLIGHT_PUBLIC_URL=
ANDROID_TESTING_URL=
BUSINESS_EXPENSES_APP_URL=http://localhost:4300

# Unique per deployment: use /home/data/... on Azure App Service, and data/... locally.
USER_STORE_PATH=data/users.json
SUBSCRIPTION_STORE_PATH=data/subscriptions.json
SUBSCRIBER_WORKSPACE_STORE_PATH=data/subscriber-workspaces.json
TRANSACTION_STORE_PATH=data/transactions.json
ISSUER_ORG_STORE_PATH=data/issuer-organizations.json
ORG_ADMIN_STORE_PATH=data/org-admin.json
ORG_ADMIN_EVENT_STORE_PATH=data/org-admin-events.json
OIDC_WALLET_SESSION_STORE_PATH=data/oidc-wallet-sessions.json
OIDC_CODE_STORE_PATH=data/oidc-codes.json
WALLET_CHALLENGE_STORE_PATH=data/wallet-challenges.json
WALLET_PASSKEY_STORE_PATH=data/wallet-passkeys.json
AUDIT_STORE_PATH=data/audit-events.json

# Unique per deployment and secret: leave blank in templates; set directly in Azure or local private env files.
SESSION_SECRET=

# Unique per deployment: passkey/WebAuthn RP ID and origin must match the host users open in their browser.
DEFAULT_MFA_METHOD=email
PASSKEY_RP_NAME=Vanguard Cloud Services - Aegis ID
PASSKEY_RP_ID=localhost
PASSKEY_ORIGIN=http://localhost:3000

# Unique per mobile app signing profile: used to publish iOS/Android associated-domain metadata.
IOS_APP_TEAM_ID=GL46AP73ZQ
IOS_APP_BUNDLE_ID=ca.vanguardcs.aegisid.wallet
ANDROID_APP_PACKAGE_NAME=ca.vanguardcs.aegisid.wallet
ANDROID_SHA256_CERT_FINGERPRINTS=

# Unique per deployment: use mock locally, live on Azure once Entra Verified ID is configured.
VID_MODE=mock
VID_CLIENT_NAME=Vanguard Cloud Services - Aegis ID
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
VID_AUTHORITY_DID=
VID_MANIFEST_URL=
VID_CREDENTIAL_TYPE=VerifiedEmployee
VID_CALLBACK_API_KEY=

# Unique per lab deployment: keep localhost for local Docker, or use hosted ACA-Py admin endpoints for Azure lab agents.
ARIES_HOLDER_ADMIN_URL=http://localhost:6011
ARIES_ISSUER_ADMIN_URL=http://localhost:4011
ARIES_VERIFIER_ADMIN_URL=http://localhost:5011
ARIES_MEDIATOR_ADMIN_URL=http://localhost:3011
ARIES_ADMIN_API_KEY=
ARIES_HOLDER_ADMIN_API_KEY=
ARIES_ISSUER_ADMIN_API_KEY=
ARIES_VERIFIER_ADMIN_API_KEY=
ARIES_MEDIATOR_ADMIN_API_KEY=

# Unique per deployment: built-in OIDC + wallet challenge demo metadata and callback behavior.
OIDC_WALLET_DEMO_MODE=mock
OIDC_WALLET_ISSUER=https://mock-idp.vanguardcs.local
OIDC_WALLET_PUBLIC_BASE_URL=
OIDC_WALLET_AUTHORIZATION_ENDPOINT=/demo/oidc-wallet/mock-authorize
OIDC_WALLET_CLIENT_ID=vanguard-aegis-wallet-gated-app
OIDC_WALLET_SCOPE=openid profile email
OIDC_WALLET_SESSION_TTL_SECONDS=900
