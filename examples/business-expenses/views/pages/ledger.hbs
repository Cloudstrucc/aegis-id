<section class="container-fluid py-4 px-lg-5">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <span class="badge text-bg-dark">Reporting</span>
      <h1 class="mt-2 mb-1">Wallet challenge ledger</h1>
      <p class="text-muted mb-0">Every high-value authentication and expense decision challenge is visible here with its signed payload.</p>
    </div>
    <a class="btn btn-primary" href="/expenses">Back to expenses</a>
  </div>

  <div class="row g-4">
    <div class="col-xl-8">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white">
          <h2 class="h5 mb-0">Aegis ID challenge records</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Time</th>
                <th>Subject</th>
                <th>Action</th>
                <th>Resource</th>
                <th>Status</th>
                <th>Payload</th>
              </tr>
            </thead>
            <tbody>
              {{#each challenges}}
                <tr>
                  <td>{{createdAt}}</td>
                  <td>{{subject}}</td>
                  <td>{{action}}</td>
                  <td>{{resourceType}} {{resourceId}}</td>
                  <td><span class="badge status-{{status}}">{{status}}</span></td>
                  <td>
                    <details>
                      <summary>{{challengeId}}</summary>
                      <pre class="small mt-2">{{json payload}}</pre>
                    </details>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-xl-4">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white">
          <h2 class="h5 mb-0">Local decision index</h2>
        </div>
        <div class="list-group list-group-flush">
          {{#each decisions}}
            <div class="list-group-item">
              <div class="d-flex justify-content-between gap-3">
                <strong>{{expenseId}}</strong>
                <span class="badge status-{{status}}">{{status}}</span>
              </div>
              <div class="text-muted small">{{action}} by {{actor}}</div>
              <code class="small">{{challengeId}}</code>
            </div>
          {{/each}}
        </div>
      </div>
    </div>
  </div>
</section>
