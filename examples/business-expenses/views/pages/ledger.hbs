<section class="container-fluid py-4 px-lg-5">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <span class="badge text-bg-dark">Reporting</span>
      <h1 class="mt-2 mb-1">Wallet challenge ledger</h1>
      <p class="text-muted mb-0">Every high-value authentication, YubiKey step-up, expense decision, and document signature challenge is visible here with its signed payload.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a class="btn btn-outline-primary" href="/signatures">E-signatures</a>
      <a class="btn btn-primary" href="/expenses">Back to expenses</a>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-xl-8">
      <div class="surface-card">
        <div class="card-header bg-white px-0 pt-0">
          <h2 class="h5 mb-0">Aegis ID challenge records</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Time</th>
                <th>Subject</th>
                <th>Action</th>
                <th>Resource</th>
                <th>Status</th>
                <th>Payload</th>
              </tr>
            </thead>
            <tbody>
              {{#each challenges}}
                <tr>
                  <td>{{createdAt}}</td>
                  <td>{{subject}}</td>
                  <td>{{action}}</td>
                  <td>{{resourceType}} {{resourceId}}</td>
                  <td><span class="badge status-{{status}}">{{status}}</span></td>
                  <td>
                    <details>
                      <summary>{{challengeId}}</summary>
                      <pre class="small mt-2">{{json payload}}</pre>
                    </details>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-xl-4">
      <div class="surface-card mb-4">
        <div class="card-header bg-white px-0 pt-0">
          <h2 class="h5 mb-0">YubiKey assurance events</h2>
        </div>
        <div class="list-group list-group-flush">
          {{#each assuranceEvents}}
            <div class="list-group-item">
              <div class="d-flex justify-content-between gap-3">
                <strong>{{subject}}</strong>
                <span class="badge status-{{status}}">{{status}}</span>
              </div>
              <div class="text-muted small">{{action}} via {{type}}</div>
              <div class="small">Credential: <code>{{credentialId}}</code></div>
              <details class="mt-2">
                <summary>Payload</summary>
                <pre class="small mt-2">{{json payload}}</pre>
              </details>
            </div>
          {{/each}}
          {{#unless assuranceEvents}}
            <div class="list-group-item text-muted">No YubiKey assurance events yet.</div>
          {{/unless}}
        </div>
      </div>

      <div class="surface-card mb-4">
        <div class="card-header bg-white px-0 pt-0">
          <h2 class="h5 mb-0">Document envelopes</h2>
        </div>
        <div class="list-group list-group-flush">
          {{#each envelopes}}
            <a class="list-group-item list-group-item-action" href="/signatures/envelopes/{{id}}">
              <div class="d-flex justify-content-between gap-3">
                <strong>{{templateName}}</strong>
                <span class="badge status-{{status}}">{{status}}</span>
              </div>
              <div class="text-muted small">{{actorEmail}} · {{signatureId}}</div>
              <code class="small">{{challengeId}}</code>
            </a>
          {{/each}}
          {{#unless envelopes}}
            <div class="list-group-item text-muted">No signature envelopes yet.</div>
          {{/unless}}
        </div>
      </div>

      <div class="surface-card">
        <div class="card-header bg-white px-0 pt-0">
          <h2 class="h5 mb-0">Local decision index</h2>
        </div>
        <div class="list-group list-group-flush">
          {{#each decisions}}
            <div class="list-group-item">
              <div class="d-flex justify-content-between gap-3">
                <strong>{{expenseId}}</strong>
                <span class="badge status-{{status}}">{{status}}</span>
              </div>
              <div class="text-muted small">{{action}} by {{actor}}</div>
              <code class="small">{{challengeId}}</code>
            </div>
          {{/each}}
        </div>
      </div>
    </div>
  </div>
</section>
