<section class="example-hero">
  <div class="container-fluid px-lg-5 py-5">
    <div class="row align-items-center g-5">
      <div class="col-xl-7">
        <p class="eyebrow">Vanguard Aegis ID App Integration Examples</p>
        <h1>High-assurance actions in real business apps.</h1>
        <p class="hero-copy">
          Use Microsoft Verified ID, YubiKey/FIDO2, and Aegis wallet challenges to prove identity, step up assurance, and sign high-value decisions.
        </p>
        {{#unless configured}}
          <div class="alert alert-warning">
            Set <code>AEGIS_ORGANIZATION_ID</code> or <code>AEGIS_ISSUER_CONNECTION_ID</code> before creating wallet challenges.
          </div>
        {{/unless}}
      </div>
      <div class="col-xl-5">
        <div class="assurance-panel">
          <div>
            <span class="panel-dot"></span>
            <strong>Verified ID</strong>
            <span>Portable credential proof</span>
          </div>
          <div>
            <span class="panel-dot"></span>
            <strong>YubiKey / FIDO2</strong>
            <span>Hardware-backed user presence</span>
          </div>
          <div>
            <span class="panel-dot"></span>
            <strong>Aegis wallet challenge</strong>
            <span>Ledgered consent and signature evidence</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container-fluid px-lg-5 py-5">
  <div class="section-heading">
    <p class="eyebrow">Example apps</p>
    <h2>Choose a demo workflow.</h2>
    <p>Authenticate once, then try expense approvals or PDF e-signatures with the same Aegis ID wallet evidence layer.</p>
  </div>

  <div class="app-tile-grid">
    <article class="app-tile">
      <span class="tile-icon"><i class="bi bi-receipt-cutoff"></i></span>
      <p class="eyebrow">Expense approvals</p>
      <h3>Business Expenses</h3>
      <p>Approve or reject expense records with a per-decision wallet challenge and immutable ledger payload.</p>
      <a class="btn btn-primary" href="/apps/expenses">Open Expenses</a>
    </article>

    <article class="app-tile">
      <span class="tile-icon"><i class="bi bi-file-earmark-check"></i></span>
      <p class="eyebrow">Document signing</p>
      <h3>E-Signatures</h3>
      <p>Upload a PDF, place a signature field, send a wallet signing challenge, and stamp the signed envelope.</p>
      <a class="btn btn-primary" href="/apps/signatures">Open E-Signatures</a>
    </article>
  </div>
</section>
