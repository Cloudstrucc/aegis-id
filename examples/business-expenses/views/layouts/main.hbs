<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}} | Vanguard Aegis Examples</title>
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/flatly/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg app-nav">
      <div class="container-fluid">
        <a class="navbar-brand app-logo-link" href="/" aria-label="Vanguard Aegis ID example app home">
          <img class="app-logo" src="/images/vanguard-cloud-services-logo.png" alt="Vanguard Cloud Services">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div id="mainNav" class="collapse navbar-collapse">
          <ul class="navbar-nav me-auto">
            <li class="nav-item"><a class="nav-link" href="/apps/expenses">Expenses</a></li>
            <li class="nav-item"><a class="nav-link" href="/apps/signatures">E-Signatures</a></li>
            <li class="nav-item"><a class="nav-link" href="/apps/ledger">Ledger</a></li>
          </ul>
          {{#if user}}
            <div class="dropdown">
              <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                {{user.email}}
              </button>
              <div class="dropdown-menu dropdown-menu-end shadow-sm">
                <a class="dropdown-item" href="/apps/expenses">Business Expenses</a>
                <a class="dropdown-item" href="/apps/signatures">E-Signatures</a>
                <a class="dropdown-item" href="/apps/ledger">Ledger</a>
                <div class="dropdown-divider"></div>
                <form action="/auth/logout" method="post">
                  <button class="dropdown-item text-danger" type="submit">Sign out</button>
                </form>
              </div>
            </div>
          {{else}}
            <div class="dropdown">
              <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                Sign in
              </button>
              <div class="dropdown-menu dropdown-menu-end auth-menu shadow-sm">
                <form action="/auth/start" method="post">
                  <input type="hidden" name="intent" value="sign-in">
                  <input type="hidden" name="authMethod" value="verified-id">
                  <input type="hidden" name="returnTo" value="{{authReturnTo}}">
                  <button class="dropdown-item" type="submit">Sign in with Verified ID</button>
                </form>
                <form action="/auth/start" method="post">
                  <input type="hidden" name="intent" value="register">
                  <input type="hidden" name="authMethod" value="verified-id">
                  <input type="hidden" name="returnTo" value="{{authReturnTo}}">
                  <button class="dropdown-item" type="submit">Register with Verified ID</button>
                </form>
                <form action="/auth/start" method="post">
                  <input type="hidden" name="intent" value="sign-in">
                  <input type="hidden" name="authMethod" value="yubikey">
                  <input type="hidden" name="returnTo" value="{{authReturnTo}}">
                  <button class="dropdown-item" type="submit">Sign in with YubiKey</button>
                </form>
                <form action="/auth/start" method="post">
                  <input type="hidden" name="intent" value="sign-in">
                  <input type="hidden" name="authMethod" value="wallet">
                  <input type="hidden" name="returnTo" value="{{authReturnTo}}">
                  <button class="dropdown-item" type="submit">Use wallet-only lab</button>
                </form>
              </div>
            </div>
          {{/if}}
        </div>
      </div>
    </nav>
    <main>
      {{{body}}}
    </main>
    <footer class="app-footer">
      <div class="container-fluid">
        <a class="footer-logo" href="/" aria-label="Vanguard Aegis ID example app home">
          <span class="footer-mark">V</span>
          <span>Vanguard Aegis ID Examples</span>
        </a>
        <nav class="footer-links" aria-label="Example app links">
          <a href="/apps/expenses">Expenses</a>
          <a href="/apps/signatures">E-Signatures</a>
          <a href="/apps/ledger">Ledger</a>
        </nav>
      </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/app.js"></script>
    <script type="module" src="/signature.js"></script>
  </body>
</html>
