# Vanguard Business Expenses environment template.
# Copy to .env for production, .env.local for localhost, .env.dev for dev Azure, or .env.qa for QA Azure.

# Unique per runtime: use development locally and production in Azure.
NODE_ENV=development

# Unique for local only. Azure App Service supplies its own listener port.
PORT=4300

# Unique per Azure deployment: deploy target for this standalone app.
AZURE_TENANT_ID=24a46daa-7b87-4566-9eea-281326a1b75c
AZURE_SUBSCRIPTION_ID=7719c366-5f64-439a-a6c6-65067d5a97e4
AZURE_RESOURCE_GROUP=rg-vanguard-aegis-id
AZURE_WEBAPP_NAME=vanguard-business-expenses-65067d
WEBSITE_NODE_DEFAULT_VERSION=~20

# Unique per deployment: public URL for this app and the Aegis ID authority it connects to.
APP_PUBLIC_BASE_URL=http://localhost:4300
AEGIS_ID_BASE_URL=http://localhost:3000

# Unique per deployment and secret: leave blank in templates; set directly in Azure or a private env file.
SESSION_SECRET=

# Aegis ID OIDC endpoints.
AEGIS_OIDC_AUTHORIZATION_ENDPOINT=/oidc/authorize
AEGIS_OIDC_TOKEN_ENDPOINT=/oidc/token

# Unique per deployment: OIDC client registration values for this relying-party app.
OIDC_CLIENT_ID=business-expenses-demo
OIDC_SCOPE=openid profile email

# Feature flags for assurance paths.
VERIFIED_ID_AUTH_ENABLED=true
YUBIKEY_AUTH_ENABLED=true

# Unique per deployment: organization workspace ID that issues wallet challenges to this app.
AEGIS_ORGANIZATION_ID=

# Optional unique fallback: raw issuer connection ID if not using organization-scoped challenges.
AEGIS_ISSUER_CONNECTION_ID=
