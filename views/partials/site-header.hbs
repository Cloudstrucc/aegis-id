<header class="site-header" aria-label="Primary">
  <a class="brand-lockup" href="/" aria-label="Go to Vanguard Cloud Services - Aegis ID home" title="Home">
    <img class="brand-logo" src="/images/vanguard-cloud-services-logo.png" alt="Vanguard Cloud Services">
    <span class="brand-product-pill">Aegis ID</span>
  </a>
  <nav class="site-nav" aria-label="Site">
    {{#if isAuthenticated}}
      <a href="/account">Account</a>
      <a href="/developer/api">Docs</a>
      <a href="/subscribe">Subscribe Org</a>
    {{else}}
      <a href="/docs/aegis-verified-id-value-story.html">Product brief</a>
      <a href="/auth/login">Sign in</a>
      <a href="/#signup">Create account</a>
    {{/if}}
    {{#if canViewHealth}}
      <a href="/health">Health</a>
    {{/if}}
    {{#if headerProfile}}
      <button class="workspace-blade__avatar site-header__profile-trigger" type="button" data-modal-target="#global-profile-modal" aria-label="Open profile">
        {{headerProfile.initials}}
      </button>
    {{/if}}
  </nav>
</header>

{{#if headerProfile}}
  <div class="app-modal" id="global-profile-modal" hidden>
    <div class="app-modal__backdrop" data-modal-close></div>
    <section class="app-modal__panel app-modal__panel--wide" role="dialog" aria-modal="true" aria-labelledby="global-profile-modal-title">
      <div class="app-modal__head">
        <div>
          <p class="eyebrow">Profile</p>
          <h2 id="global-profile-modal-title">{{headerProfile.displayName}}</h2>
          <p>{{headerProfile.email}}</p>
        </div>
        <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
      </div>
      <div class="profile-modal-grid">
        <article class="profile-summary-card profile-summary-card--table">
          <h3>Basic information</h3>
          <dl class="definition-list definition-list--compact">
            <div><span>Email</span><strong>{{headerProfile.email}}</strong></div>
            <div><span>Phone</span><strong>{{headerProfile.phone}}</strong></div>
            <div><span>Preferred MFA</span><strong>{{headerProfile.preferredMfa}}</strong></div>
            <div><span>Registered passkeys</span><strong>{{headerProfile.passkeyCount}}</strong></div>
            <div><span>Last second factor</span><strong>{{headerProfile.lastSecondFactorAtLabel}}</strong></div>
            <div><span>Account created</span><strong>{{headerProfile.createdAtLabel}}</strong></div>
          </dl>
        </article>
        <article class="profile-summary-card profile-summary-card--table">
          <h3>Organizations</h3>
          {{#if headerProfile.hasOrganizations}}
            <div class="profile-org-list">
              {{#each headerProfile.organizations}}
                <div class="profile-org-row">
                  <div>
                    <strong>{{organizationName}}</strong>
                    <span>{{persona}} · {{status}}</span>
                  </div>
                  <small>{{roleSummary}}</small>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="muted">No organization memberships are currently associated with this account.</p>
          {{/if}}
        </article>
      </div>
      <div class="modal-actions modal-actions--profile">
        <form action="/auth/logout" method="post">
          <button class="button" type="submit">Sign out</button>
        </form>
        <button class="button button--secondary button--dark-text" type="button" data-modal-close>Close</button>
      </div>
    </section>
  </div>
{{/if}}
