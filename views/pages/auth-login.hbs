<section class="page-hero page-hero--compact">
  <p class="eyebrow">Subscriber access</p>
  <h1>Sign in to Aegis ID.</h1>
  <p>Use your subscriber account before opening organization dashboards, setup wizards, or wallet challenge demos.</p>
</section>

<section class="band band--white">
  <div class="auth-grid auth-grid--compact">
    <div class="section-heading">
      <p class="eyebrow">Passport.js</p>
      <h2>Password first, second factor next.</h2>
      <p>Organization subscription and administration require an authenticated user session plus email, SMS, or passkey verification.</p>
    </div>

    <form class="subscribe-form" action="/auth/login" method="post" novalidate>
      {{#if errorMessage}}<p class="form-alert">{{errorMessage}}</p>{{/if}}
      <div class="field-group">
        <label for="email">Work email</label>
        <input id="email" name="email" type="email" value="{{formValues.email}}" autocomplete="email" required>
      </div>
      <div class="field-group">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" autocomplete="current-password" required>
      </div>
      <button class="button button--primary" type="submit">Continue</button>
      <p class="form-footnote">Need access? <a href="/auth/register">Create an account</a>.</p>
    </form>
  </div>
</section>
