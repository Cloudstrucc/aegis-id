<section class="page-hero page-hero--compact">
  <p class="eyebrow">{{workspaceRole}} Dashboard</p>
  <h1>{{workspace.organization}} Aegis ID setup</h1>
  <p>{{#if welcome}}Subscription captured. Start by connecting Microsoft Entra Verified ID, then add federation providers as needed.{{else}}Manage connected identity platforms and setup progress for this Aegis ID workspace.{{/if}}</p>
  <div class="hero__actions">
    <a class="button button--primary" href="{{dashboardBasePath}}/platforms/microsoft-verified-id/setup">Set Up Verified ID</a>
    <a class="button button--secondary" href="{{organizationsPath}}">Organizations</a>
    <a class="button button--secondary" href="/architecture">Architecture</a>
  </div>
</section>

<section class="band band--light">
  <div class="dashboard-summary">
    <article>
      <span class="metric">{{connectedCount}}</span>
      <p>Connected platforms</p>
    </article>
    <article>
      <span class="metric">{{inProgressCount}}</span>
      <p>Configured or in progress</p>
    </article>
    <article>
      <span class="metric">{{verifiedIdMode}}</span>
      <p>Server Verified ID mode</p>
    </article>
  </div>
</section>

<section id="credential-admin" class="band band--white">
  <div class="section-heading">
    <p class="eyebrow">Credential Administration</p>
    <h2>Issue, monitor, update, and revoke organization credentials.</h2>
    <p>Admins can manage claims, roles, holder invitations, co-admin requests, branding, and immutable wallet challenge logs for this organization.</p>
  </div>

  <div class="dashboard-summary dashboard-summary--four">
    <article>
      <span class="metric">{{orgAdmin.activeCount}}</span>
      <p>Active credentials</p>
    </article>
    <article>
      <span class="metric">{{orgAdmin.invitedCount}}</span>
      <p>Invited</p>
    </article>
    <article>
      <span class="metric">{{orgAdmin.revokedCount}}</span>
      <p>Revoked</p>
    </article>
    <article>
      <span class="metric">{{orgAdmin.coAdminCount}}</span>
      <p>Co-admins</p>
    </article>
  </div>

  {{#if orgAdmin.isAdmin}}
    <div class="admin-grid">
      <article class="platform-card">
        <div class="platform-card__head">
          <span class="platform-icon">ID</span>
          <div>
            <span class="track-label">Issue credential</span>
            <h3>Invite a credential holder</h3>
          </div>
        </div>
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/credentials" method="post">
          <div class="field-row">
            <div class="field-group">
              <label for="holderEmail">Holder email</label>
              <input id="holderEmail" name="holderEmail" type="email" value="identity@vanguardcs.ca" required>
            </div>
            <div class="field-group">
              <label for="displayName">Display name</label>
              <input id="displayName" name="displayName" type="text" value="Vanguard Team Member" required>
            </div>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label for="personType">Person type</label>
              <select id="personType" name="personType" title="Classifies the holder for directory filtering and default role workflows.">
                {{#each orgAdmin.personTypes}}
                  <option value="{{id}}">{{name}}</option>
                {{/each}}
              </select>
            </div>
            <div class="field-group">
              <label for="divisionId">Division / sub-organization</label>
              <select id="divisionId" name="divisionId" title="Places this credential in the organization's division tree.">
                {{#each orgAdmin.orgUnitOptions}}
                  <option value="{{id}}">{{indentedName}}</option>
                {{/each}}
              </select>
            </div>
            <div class="field-group">
              <label for="inviteTtlDays">Invite expiry days</label>
              <input id="inviteTtlDays" name="inviteTtlDays" type="number" min="1" max="365" value="7" title="Default is 7 days. Override this for contractors or time-sensitive onboarding.">
            </div>
          </div>
          <div class="checkbox-grid">
            {{#each orgAdmin.roles}}
              <label class="checkline">
                <input type="checkbox" name="roleIds" value="{{id}}">
                <span>{{name}}</span>
              </label>
            {{/each}}
          </div>
          <div>
            <p class="form-note">Claims requested by wallet consent challenge</p>
            <div class="checkbox-grid">
              {{#each orgAdmin.claimConsentOptions}}
                <label class="checkline" title="The holder must consent before this organization can use this claim.">
                  <input type="checkbox" name="requestedClaimKeys" value="{{key}}" {{#if checked}}checked{{/if}}>
                  <span>{{label}}</span>
                </label>
              {{/each}}
            </div>
          </div>
          <div class="claim-edit-grid">
            {{#each orgAdmin.claimDefinitions}}
              <div class="field-group">
                <label for="issue-claim-{{key}}">{{label}}</label>
                <input id="issue-claim-{{key}}" name="claim_{{key}}" type="{{type}}" value="{{defaultValue}}">
              </div>
            {{/each}}
          </div>
          <button class="button button--primary button--blue" type="submit">Issue Credential</button>
        </form>
      </article>

      <article class="platform-card">
        <div class="platform-card__head">
          <span class="platform-icon">LOG</span>
          <div>
            <span class="track-label">Immutable log</span>
            <h3>Wallet challenge events</h3>
          </div>
        </div>
        <div class="event-list">
          {{#each orgAdmin.events}}
            <details>
              <summary>{{title}} <span>{{createdAt}}</span></summary>
              <pre>{{details}}</pre>
            </details>
          {{/each}}
        </div>
      </article>
    </div>
  {{else}}
    <article class="note-panel">
      <strong>Contributor view</strong>
      <span>You can view organization state, but credential issuance and administration require administrator access.</span>
    </article>
  {{/if}}

  <div id="org-structure" class="structure-layout">
    <article class="platform-card">
      <div class="platform-card__head">
        <span class="platform-icon">ORG</span>
        <div>
          <span class="track-label">Sub-organizations</span>
          <h3>Organization structure</h3>
        </div>
      </div>
      <div class="org-chart-canvas" aria-label="Organization structure tree">
        {{#each orgAdmin.orgChartNodes}}
          <div class="org-node" style="--depth: {{depth}};">
            <strong>{{name}}</strong>
            <span>{{path}}</span>
            <small>{{credentialCount}} credential{{#unless (eq credentialCount 1)}}s{{/unless}}</small>
            <div class="tag-row">
              {{#each roleLabels}}
                <span>{{this}}</span>
              {{/each}}
              {{#each claimLabels}}
                <span>{{this}}</span>
              {{/each}}
            </div>
            {{#if ../orgAdmin.isAdmin}}
              {{#unless (eq id "unit-root")}}
                <form action="{{../dashboardBasePath}}/admin/org-units/{{id}}/delete" method="post">
                  <button class="button button--ghost" type="submit">Delete Node</button>
                </form>
              {{/unless}}
            {{/if}}
          </div>
        {{/each}}
      </div>
    </article>

    {{#if orgAdmin.isAdmin}}
      <article class="platform-card">
        <div class="platform-card__head">
          <span class="platform-icon">DIV</span>
          <div>
            <span class="track-label">Org chart editor</span>
            <h3>Add a division</h3>
          </div>
        </div>
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/org-units" method="post">
          <div class="field-row">
            <div class="field-group">
              <label for="orgUnitName">Division name</label>
              <input id="orgUnitName" name="name" type="text" placeholder="Finance, HR, Delivery">
            </div>
            <div class="field-group">
              <label for="orgUnitParent">Parent node</label>
              <select id="orgUnitParent" name="parentId">
                {{#each orgAdmin.orgUnitOptions}}
                  <option value="{{id}}">{{indentedName}}</option>
                {{/each}}
              </select>
            </div>
          </div>
          <div class="field-group">
            <label for="orgUnitDescription">Description</label>
            <textarea id="orgUnitDescription" name="description" rows="3" placeholder="Optional privileges or business context."></textarea>
          </div>
          <div>
            <p class="form-note">Default roles for this node</p>
            <div class="checkbox-grid">
              {{#each orgAdmin.roles}}
                <label class="checkline">
                  <input type="checkbox" name="roleIds" value="{{id}}">
                  <span>{{name}}</span>
                </label>
              {{/each}}
            </div>
          </div>
          <div>
            <p class="form-note">Claims normally requested in this node</p>
            <div class="checkbox-grid">
              {{#each orgAdmin.claimDefinitions}}
                <label class="checkline">
                  <input type="checkbox" name="claimKeys" value="{{key}}">
                  <span>{{label}}</span>
                </label>
              {{/each}}
            </div>
          </div>
          <button class="button button--primary button--blue" type="submit">Add Division</button>
        </form>
      </article>
    {{/if}}
  </div>

  <div id="people-directory" class="people-directory">
    <div class="people-directory__head">
      <div>
        <p class="eyebrow">People directory</p>
        <h3>Credential holders and invitations</h3>
        <p>{{orgAdmin.peopleTable.pageSummary}} people shown. Invitations default to 7 days unless overridden.</p>
      </div>
      <form class="people-filters" action="{{dashboardBasePath}}" method="get">
        <input name="peopleSearch" type="search" value="{{orgAdmin.peopleTable.search}}" placeholder="Search people, email, role">
        <select name="peopleStatus">
          {{#each orgAdmin.peopleTable.statusOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <select name="peopleType">
          {{#each orgAdmin.peopleTable.personTypeOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <button class="button button--secondary button--dark-text" type="submit">Apply</button>
      </form>
    </div>

    <div class="people-table-wrap">
      <table class="people-table">
        <thead>
          <tr>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.displayName}}">Name</a></th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.holderEmail}}">Email</a></th>
            <th>Type</th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.divisionName}}">Division</a></th>
            <th>Roles</th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.status}}">Status</a></th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.inviteExpiresAt}}">Invite expiry</a></th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.consent}}">Consent</a></th>
          </tr>
        </thead>
        <tbody>
          {{#each orgAdmin.peopleTable.rows}}
            <tr>
              <td><a href="#credential-{{id}}">{{displayName}}</a></td>
              <td>{{holderEmail}}</td>
              <td>{{personTypeLabel}}</td>
              <td>{{divisionName}}</td>
              <td>
                <div class="tag-row tag-row--compact">
                  {{#each roleLabels}}
                    <span>{{this}}</span>
                  {{/each}}
                </div>
              </td>
              <td><span class="status-pill status-pill--{{status}}">{{statusLabel}}</span></td>
              <td>
                {{inviteExpiresLabel}}
                {{#if inviteExpired}}
                  <span class="status-pill status-pill--revoked">Expired</span>
                {{/if}}
              </td>
              <td><span class="status-pill status-pill--consent">{{consentStatusLabel}}</span></td>
            </tr>
          {{/each}}
        </tbody>
      </table>
      {{#if orgAdmin.peopleTable.empty}}
        <p class="empty-table-note">No credential holders match these filters.</p>
      {{/if}}
    </div>
    <div class="people-pagination">
      {{#if orgAdmin.peopleTable.hasPrevious}}
        <a class="button button--secondary button--dark-text" href="{{orgAdmin.peopleTable.previousUrl}}">Previous</a>
      {{/if}}
      <span>Page {{orgAdmin.peopleTable.page}} of {{orgAdmin.peopleTable.pageCount}}</span>
      {{#if orgAdmin.peopleTable.hasNext}}
        <a class="button button--secondary button--dark-text" href="{{orgAdmin.peopleTable.nextUrl}}">Next</a>
      {{/if}}
    </div>
  </div>

  <div class="credential-grid">
    {{#each orgAdmin.credentials}}
      <article id="credential-{{id}}" class="credential-card credential-card--{{status}}">
        <div class="credential-card__head">
          <div>
            <span class="track-label">{{statusLabel}}</span>
            <h3>{{displayName}}</h3>
            <p>{{holderEmail}}</p>
          </div>
          <span class="credential-status">{{statusLabel}}</span>
        </div>

        <div class="tag-row">
          <span>{{personTypeLabel}}</span>
          <span>{{divisionName}}</span>
          <span>Invite expires {{inviteExpiresLabel}}</span>
          {{#each roleLabels}}
            <span>{{this}}</span>
          {{/each}}
          {{#if coAdminStatus}}
            <span>Co-admin: {{coAdminStatus}}</span>
          {{/if}}
          <span>{{consentStatusLabel}}</span>
        </div>

        <details>
          <summary>Credential profile and transactions</summary>
          <dl class="claim-list">
            {{#each claimFields}}
              <div>
                <dt>{{label}}</dt>
                <dd>{{value}}</dd>
              </div>
            {{/each}}
          </dl>
          <div class="consent-panel">
            <h4>Consent-scoped claims</h4>
            <p>Only claims granted by the holder are available to this organization context.</p>
            <div class="tag-row">
              {{#each requestedClaimLabels}}
                <span>Requested: {{this}}</span>
              {{/each}}
              {{#each deltaClaimLabels}}
                <span>Delta supplied: {{this}}</span>
              {{/each}}
            </div>
            {{#if sharedClaimFields}}
              <dl class="claim-list">
                {{#each sharedClaimFields}}
                  <div>
                    <dt>{{label}}</dt>
                    <dd>{{value}}</dd>
                  </div>
                {{/each}}
              </dl>
            {{/if}}
          </div>
          <div class="event-list event-list--compact">
            {{#each events}}
              <details>
                <summary>{{title}} <span>{{createdAt}}</span></summary>
                <pre>{{details}}</pre>
              </details>
            {{/each}}
          </div>
        </details>

        {{#if ../orgAdmin.isAdmin}}
          <details>
            <summary>Admin actions</summary>
            <form class="wizard-form" action="{{../dashboardBasePath}}/admin/credentials/{{id}}/update" method="post">
              <div class="field-row">
                <div class="field-group">
                  <label for="holder-{{id}}">Holder email</label>
                  <input id="holder-{{id}}" name="holderEmail" type="email" value="{{holderEmail}}">
                </div>
                <div class="field-group">
                  <label for="name-{{id}}">Display name</label>
                  <input id="name-{{id}}" name="displayName" type="text" value="{{displayName}}">
                </div>
                <div class="field-group">
                  <label for="type-{{id}}">Person type</label>
                  <select id="type-{{id}}" name="personType">
                    {{#each personTypeOptions}}
                      <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                </div>
                <div class="field-group">
                  <label for="division-{{id}}">Division</label>
                  <select id="division-{{id}}" name="divisionId">
                    {{#each divisionOptions}}
                      <option value="{{id}}" {{#if selected}}selected{{/if}}>{{indentedName}}</option>
                    {{/each}}
                  </select>
                </div>
                <div class="field-group">
                  <label for="ttl-{{id}}">Invite expiry days</label>
                  <input id="ttl-{{id}}" name="inviteTtlDays" type="number" min="1" max="365" value="{{inviteTtlDays}}">
                </div>
              </div>
              <div class="checkbox-grid">
                {{#each availableRoles}}
                  <label class="checkline">
                    <input type="checkbox" name="roleIds" value="{{id}}" {{#if checked}}checked{{/if}}>
                    <span>{{name}}</span>
                  </label>
                {{/each}}
              </div>
              <div class="claim-edit-grid">
                {{#each claimFields}}
                  <div class="field-group">
                    <label for="credential-{{../id}}-{{key}}">{{label}}</label>
                    <input id="credential-{{../id}}-{{key}}" name="claim_{{key}}" type="{{type}}" value="{{value}}">
                  </div>
                {{/each}}
              </div>
              <div>
                <p class="form-note">Claims to request by wallet consent challenge</p>
                <div class="checkbox-grid">
                  {{#each consentClaimFields}}
                    <label class="checkline">
                      <input type="checkbox" name="requestedClaimKeys" value="{{key}}" {{#if checked}}checked{{/if}}>
                      <span>{{label}}</span>
                    </label>
                  {{/each}}
                </div>
              </div>
              <button class="button button--primary button--blue" type="submit">Update Claims and Roles</button>
            </form>

            <div class="consent-actions">
              <form class="wizard-form" action="{{../dashboardBasePath}}/admin/credentials/{{id}}/consent/request" method="post">
                <p class="form-note">Send a wallet challenge requesting consent to share these claims with {{organizationName}}.</p>
                <div class="checkbox-grid">
                  {{#each consentClaimFields}}
                    <label class="checkline">
                      <input type="checkbox" name="requestedClaimKeys" value="{{key}}" {{#if checked}}checked{{/if}}>
                      <span>{{label}}</span>
                    </label>
                  {{/each}}
                </div>
                <button class="button button--secondary button--dark-text" type="submit">Request Claim Consent</button>
              </form>

              <form class="wizard-form" action="{{../dashboardBasePath}}/admin/credentials/{{id}}/consent/grant" method="post">
                <p class="form-note">Lab simulator: record holder consent and optional delta claim values.</p>
                <div class="claim-edit-grid">
                  {{#each consentClaimFields}}
                    <div class="field-group">
                      <label for="consent-{{../id}}-{{key}}">
                        <input type="checkbox" name="sharedClaimKeys" value="{{key}}" {{#if checked}}checked{{/if}}>
                        {{label}}
                      </label>
                      <input id="consent-{{../id}}-{{key}}" name="consent_claim_{{key}}" type="{{type}}" value="{{value}}">
                    </div>
                  {{/each}}
                </div>
                <button class="button button--primary button--blue" type="submit">Simulate Wallet Consent</button>
              </form>
            </div>

            <div class="credential-actions">
              {{#if (eq status "invited")}}
                <form action="{{../dashboardBasePath}}/admin/credentials/{{id}}/accept" method="post">
                  <button class="button button--primary" type="submit">Mark Accepted</button>
                </form>
              {{/if}}
              {{#if (eq status "active")}}
                {{#if coAdminRequestId}}
                  <form action="{{../dashboardBasePath}}/admin/co-admin/{{coAdminRequestId}}/admin/accept" method="post">
                    <button class="button button--secondary button--dark-text" type="submit">Accept Admin Challenge</button>
                  </form>
                  <form action="{{../dashboardBasePath}}/admin/co-admin/{{coAdminRequestId}}/holder/accept" method="post">
                    <button class="button button--secondary button--dark-text" type="submit">Accept Holder Challenge</button>
                  </form>
                  <form action="{{../dashboardBasePath}}/admin/credentials/{{id}}/co-admin/revoke" method="post">
                    <button class="button button--ghost" type="submit">Revoke Co-admin</button>
                  </form>
                {{else}}
                  <form action="{{../dashboardBasePath}}/admin/credentials/{{id}}/co-admin/request" method="post">
                    <button class="button button--secondary button--dark-text" type="submit">Promote to Co-admin</button>
                  </form>
                {{/if}}
              {{/if}}
              {{#unless (eq status "revoked")}}
                <form class="inline-revoke-form" action="{{../dashboardBasePath}}/admin/credentials/{{id}}/revoke" method="post">
                  <input name="reason" type="text" placeholder="Revocation reason">
                  <button class="button button--ghost" type="submit">Revoke Credential</button>
                </form>
              {{/unless}}
            </div>
          </details>
        {{/if}}
      </article>
    {{/each}}
  </div>
</section>

<section id="external-wallet-ledger" class="band band--light">
  <div class="section-heading">
    <p class="eyebrow">External app ledger</p>
    <h2>High-assurance wallet challenges from connected applications.</h2>
    <p>Authentication, approvals, rejections, and contract-style decisions are captured here with immutable wallet payloads for organization reporting.</p>
  </div>

  <div class="people-directory">
    <div class="people-directory__head">
      <div>
        <p class="eyebrow">Reporting</p>
        <h3>Recent wallet-signed actions</h3>
        <p>These records are created by apps such as Business Expenses when they request a wallet signature.</p>
      </div>
      <a class="button button--secondary button--dark-text" href="#issuer-orgs">Connect issuing org</a>
    </div>

    {{#if hasWalletChallengeLedger}}
      <div class="people-table-wrap">
        <table class="people-table">
          <thead>
            <tr>
              <th>Application</th>
              <th>Subject</th>
              <th>Action</th>
              <th>Resource</th>
              <th>Status</th>
              <th>Timestamp</th>
              <th>Payload</th>
            </tr>
          </thead>
          <tbody>
            {{#each walletChallengeLedger}}
              <tr>
                <td>{{appName}}</td>
                <td>{{subject}}</td>
                <td>{{action}}</td>
                <td>{{resourceType}} {{resourceId}}</td>
                <td><span class="status-pill status-pill--{{status}}">{{status}}</span></td>
                <td>{{createdAt}}</td>
                <td>
                  <details>
                    <summary>{{challengeId}}</summary>
                    <dl class="claim-list">
                      {{#each payloadFields}}
                        <div>
                          <dt>{{key}}</dt>
                          <dd>{{value}}</dd>
                        </div>
                      {{/each}}
                    </dl>
                  </details>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <article class="note-panel">
        <strong>No external wallet challenge records yet.</strong>
        <span>Run the Business Expenses example, sign in with Aegis ID, then approve or reject an expense with the iOS wallet.</span>
      </article>
    {{/if}}
  </div>
</section>

<section id="roles-claims" class="band band--light">
  <div class="section-heading">
    <p class="eyebrow">Roles and claims</p>
    <h2>Define what this organization can issue.</h2>
  </div>
  <div class="admin-grid">
    <article class="platform-card">
      <h3>Roles</h3>
      <div class="definition-list">
        {{#each orgAdmin.roles}}
          <div>
            <strong>{{name}}</strong>
            <span>{{description}}</span>
            {{#if ../orgAdmin.isAdmin}}
              <form action="{{../dashboardBasePath}}/admin/roles/{{id}}/delete" method="post">
                <button class="button button--ghost" type="submit">Delete</button>
              </form>
            {{/if}}
          </div>
        {{/each}}
      </div>
      {{#if orgAdmin.isAdmin}}
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/roles" method="post">
          <div class="field-group">
            <label for="roleName">Role name</label>
            <input id="roleName" name="name" type="text">
          </div>
          <div class="field-group">
            <label for="roleDescription">Description</label>
            <textarea id="roleDescription" name="description" rows="3"></textarea>
          </div>
          <button class="button button--primary button--blue" type="submit">Create Role</button>
        </form>
      {{/if}}
    </article>

    <article class="platform-card">
      <h3>Claims</h3>
      <div class="definition-list">
        {{#each orgAdmin.claimDefinitions}}
          <div>
            <strong>{{label}}</strong>
            <span>{{key}} · {{type}}</span>
            {{#if ../orgAdmin.isAdmin}}
              <form action="{{../dashboardBasePath}}/admin/claims/{{id}}/delete" method="post">
                <button class="button button--ghost" type="submit">Delete</button>
              </form>
            {{/if}}
          </div>
        {{/each}}
      </div>
      {{#if orgAdmin.isAdmin}}
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/claims" method="post">
          <div class="field-row">
            <div class="field-group">
              <label for="claimLabel">Claim label</label>
              <input id="claimLabel" name="label" type="text">
            </div>
            <div class="field-group">
              <label for="claimKey">Claim key</label>
              <input id="claimKey" name="key" type="text">
            </div>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label for="claimType">Type</label>
              <select id="claimType" name="type">
                <option value="text">Text</option>
                <option value="email">Email</option>
                <option value="number">Number</option>
                <option value="date">Date</option>
              </select>
            </div>
            <div class="field-group">
              <label for="claimDefault">Default value</label>
              <input id="claimDefault" name="defaultValue" type="text">
            </div>
          </div>
          <label class="checkline">
            <input name="required" type="checkbox" value="yes">
            <span>Required claim</span>
          </label>
          <button class="button button--primary button--blue" type="submit">Create Claim</button>
        </form>
      {{/if}}
    </article>
  </div>
</section>

<section id="org-branding" class="band band--white">
  <div class="section-heading">
    <p class="eyebrow">Organization branding</p>
    <h2>Control the wallet context for this org.</h2>
    <p>Choose a palette or upload a small logo. The org profile API exposes this branding to the iOS wallet when it is viewing this organization context.</p>
  </div>
  <div class="admin-grid">
    <article class="brand-preview-card" style="--brand-primary: {{orgAdmin.branding.primaryColor}}; --brand-accent: {{orgAdmin.branding.accentColor}}; --brand-bg: {{orgAdmin.branding.backgroundColor}}; --brand-text: {{orgAdmin.branding.textColor}};">
      {{#if orgAdmin.branding.logoDataUrl}}
        <img src="{{orgAdmin.branding.logoDataUrl}}" alt="{{workspace.organization}} logo">
      {{else}}
        <span>V</span>
      {{/if}}
      <h3>{{workspace.organization}}</h3>
      <p>Aegis ID wallet profile</p>
    </article>

    {{#if orgAdmin.isAdmin}}
      <form class="platform-card wizard-form" action="{{dashboardBasePath}}/admin/branding" method="post">
        <div class="field-group">
          <label for="paletteId">Palette</label>
          <select id="paletteId" name="paletteId">
            {{#each orgAdmin.palettes}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
            {{/each}}
            <option value="custom" {{#if orgAdmin.customPaletteSelected}}selected{{/if}}>Custom palette</option>
          </select>
        </div>
        <div class="field-row">
          <div class="field-group">
            <label for="primaryColor">Primary</label>
            <input id="primaryColor" name="primaryColor" type="color" value="{{orgAdmin.branding.primaryColor}}">
          </div>
          <div class="field-group">
            <label for="accentColor">Accent</label>
            <input id="accentColor" name="accentColor" type="color" value="{{orgAdmin.branding.accentColor}}">
          </div>
        </div>
        <div class="field-row">
          <div class="field-group">
            <label for="backgroundColor">Background</label>
            <input id="backgroundColor" name="backgroundColor" type="color" value="{{orgAdmin.branding.backgroundColor}}">
          </div>
          <div class="field-group">
            <label for="textColor">Text</label>
            <input id="textColor" name="textColor" type="color" value="{{orgAdmin.branding.textColor}}">
          </div>
        </div>
        <div class="field-group">
          <label for="logoUpload">Logo upload</label>
          <input id="logoUpload" type="file" accept="image/png,image/jpeg,image/webp" data-logo-upload>
          <input type="hidden" name="logoDataUrl" data-logo-data-url>
        </div>
        <button class="button button--primary button--blue" type="submit">Save Branding</button>
      </form>
    {{/if}}
  </div>
</section>

<section id="issuer-orgs" class="band band--white">
  <div class="section-heading">
    <p class="eyebrow">Issuing organization</p>
    <h2>Create the org credential invitation used by the wallet challenge.</h2>
    <p>The OIDC wallet test can send a challenge from any org that has an accepted issuer connection.</p>
  </div>

  <div class="issuer-org-layout">
    <article class="platform-card">
      <div class="platform-card__head">
        <span class="platform-icon">ORG</span>
        <div>
          <span class="track-label">Subscriber org</span>
          <h3>{{workspace.organization}}</h3>
        </div>
      </div>
      <p>Create an Aries issuer invitation branded to this organization. After the iOS wallet accepts it, the org appears as a selectable challenge sender in the OIDC wallet demo.</p>
      <form action="{{dashboardBasePath}}/issuer-organizations/invitations" method="post">
        <button class="button button--primary button--blue" type="submit">Create Org Issuer Invitation</button>
      </form>
    </article>

    {{#if hasIssuerOrganizations}}
      {{#each issuerOrganizations}}
        <article class="demo-qr-card">
          <p class="eyebrow">{{status}}</p>
          <h3>{{organizationName}}</h3>
          <p class="demo-qr-card__description">Scan with the Vanguard Aegis ID wallet, accept the invitation, then fetch OIDC challenges from this issuer connection.</p>
          {{#if iosQrCodeDataUrl}}
            <img class="demo-qr-card__image" src="{{iosQrCodeDataUrl}}" alt="{{organizationName}} issuer invitation QR code">
          {{/if}}
          <code class="demo-qr-card__url">{{iosDeepLinkUrl}}</code>
          <dl class="claim-list">
            <div>
              <dt>Status</dt>
              <dd>{{status}}</dd>
            </div>
            <div>
              <dt>Issuer connection</dt>
              <dd>{{#if issuerConnectionId}}{{issuerConnectionId}}{{else}}Waiting for wallet acceptance{{/if}}</dd>
            </div>
            <div>
              <dt>Invitation</dt>
              <dd>{{invitationId}}</dd>
            </div>
          </dl>
        </article>
      {{/each}}
    {{else}}
      <article class="note-panel">
        <strong>No org issuer invitations yet.</strong>
        <span>Create an invitation, then accept it in the iOS wallet to make this org available for OIDC wallet challenges.</span>
      </article>
    {{/if}}
  </div>
</section>

<section class="band band--white">
  <div class="section-heading">
    <p class="eyebrow">Identity platforms</p>
    <h2>Connect Aegis ID to the platforms this subscriber uses.</h2>
  </div>

  <div class="platform-grid">
    {{#each platforms}}
      <article class="platform-card platform-card--{{status}}">
        <div class="platform-card__head">
          <span class="platform-icon">{{icon}}</span>
          <div>
            <span class="track-label">{{family}}</span>
            <h3>{{name}}</h3>
          </div>
        </div>
        <p>{{summary}}</p>
        <div class="progress-bar" aria-label="{{completed}} of {{total}} setup steps complete">
          <span style="width: {{progressPercent}}%"></span>
        </div>
        <div class="platform-card__meta">
          <span>{{statusLabel}}</span>
          <span>{{completed}} / {{total}}</span>
        </div>
        {{#if lastTestResult}}
          <p class="platform-result {{#if lastTestResult.ok}}platform-result--ok{{else}}platform-result--bad{{/if}}">
            {{lastTestResult.title}}
          </p>
        {{/if}}
        <div class="platform-card__actions">
          <a class="button button--primary" href="{{../dashboardBasePath}}/platforms/{{id}}/setup">Open Wizard</a>
          <a class="button button--ghost" href="{{docsUrl}}">Docs</a>
        </div>
      </article>
    {{/each}}
  </div>
</section>
