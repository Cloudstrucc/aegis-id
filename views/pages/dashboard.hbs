            <label for="orgUnitAvatar">Node picture</label>
            <input id="orgUnitAvatar" type="file" accept="image/*" data-image-to-hidden="org-unit-avatar-new">
            <input type="hidden" name="avatarDataUrl" data-image-hidden="org-unit-avatar-new">
          </div>
          <div>
            <p class="form-note">Default roles for this node</p>
            <div class="checkbox-grid">
              {{#each orgAdmin.roles}}
                <label class="checkline">
                  <input type="checkbox" name="roleIds" value="{{id}}">
                  <span>{{name}}</span>
                </label>
              {{/each}}
            </div>
          </div>
          <div>
            <p class="form-note">Claims normally requested in this node</p>
            <div class="checkbox-grid">
              {{#each orgAdmin.claimDefinitions}}
                <label class="checkline">
                  <input type="checkbox" name="claimKeys" value="{{key}}">
                  <span>{{label}}</span>
                </label>
              {{/each}}
            </div>
          </div>
          <div class="modal-actions">
            <button class="button button--primary button--blue" type="submit">Add Division</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>
    </div>

    {{#each orgAdmin.orgChartNodes}}
      <div class="app-modal" id="{{detailModalId}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel app-modal__panel--wide" role="dialog" aria-modal="true" aria-labelledby="org-unit-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">{{#if (eq id "unit-root")}}Root organization{{else}}Division details{{/if}}</p>
              <h2 id="org-unit-title-{{id}}">{{name}}</h2>
              <p>{{path}} · {{credentialCount}} credential{{#unless (eq credentialCount 1)}}s{{/unless}}</p>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>

          {{#if deleteBlocked}}
            <article class="note-panel note-panel--warning">
              <strong>This division has active users.</strong>
              <span>Open the People blade, filter by this division, then revoke those users or edit them to another division before deleting the node.</span>
              <a class="button button--secondary button--dark-text" href="{{peopleFilterUrl}}">Open filtered people list</a>
            </article>
          {{/if}}

          <form class="wizard-form" action="{{../dashboardBasePath}}/admin/org-units/{{id}}/update" method="post">
            <div class="field-row">
              <div class="field-group">
                <label for="orgUnitName-{{id}}">Name</label>
                <input id="orgUnitName-{{id}}" name="name" type="text" value="{{name}}">
              </div>
              {{#unless (eq id "unit-root")}}
                <div class="field-group">
                  <label for="orgUnitParent-{{id}}">Parent node</label>
                  <select id="orgUnitParent-{{id}}" name="parentId">
                    {{#each parentOptions}}
                      <option value="{{id}}" {{#if selected}}selected{{/if}}>{{indentedName}}</option>
                    {{/each}}
                  </select>
                </div>
              {{/unless}}
              <div class="field-group">
                <label for="orgUnitAvatar-{{id}}">Node picture</label>
                <input id="orgUnitAvatar-{{id}}" type="file" accept="image/*" data-image-to-hidden="org-unit-avatar-{{id}}">
                <input type="hidden" name="avatarDataUrl" value="{{avatarDataUrl}}" data-image-hidden="org-unit-avatar-{{id}}">
              </div>
            </div>
            <div class="field-group">
              <label for="orgUnitDescription-{{id}}">Description</label>
              <textarea id="orgUnitDescription-{{id}}" name="description" rows="4" placeholder="Optional privileges or business context.">{{description}}</textarea>
            </div>
            <div>
              <p class="form-note">People in this division</p>
              {{#if people}}
                <div class="org-chart-people-list">
                  {{#each people}}
                    <button class="org-chart-person-row" type="button" data-modal-target="#{{detailModalId}}">
                      <span>{{initials}}</span>
                      <strong>{{displayName}}</strong>
                      <small>{{personTypeLabel}}</small>
                    </button>
                  {{/each}}
                </div>
              {{else}}
                <p class="form-note">No credential holders are currently assigned to this division.</p>
              {{/if}}
            </div>
            <div>
              <p class="form-note">Default roles for this node</p>
              <div class="checkbox-grid">
                {{#each availableRoles}}
                  <label class="checkline">
                    <input type="checkbox" name="roleIds" value="{{id}}" {{#if checked}}checked{{/if}}>
                    <span>{{name}}</span>
                  </label>
                {{/each}}
              </div>
            </div>
            <div>
              <p class="form-note">Claims normally requested in this node</p>
              <div class="checkbox-grid">
                {{#each availableClaims}}
                  <label class="checkline">
                    <input type="checkbox" name="claimKeys" value="{{key}}" {{#if checked}}checked{{/if}}>
                    <span>{{label}}</span>
                  </label>
                {{/each}}
              </div>
            </div>
            <div class="modal-actions">
              {{#if ../orgAdmin.canManagePeople}}
                <button class="button button--primary button--blue" type="button" data-modal-target="#modal-add-user">Add Person</button>
              {{/if}}
              {{#unless (eq id "unit-root")}}
                <button class="button button--secondary button--dark-text" type="button" data-modal-target="#modal-add-division">Add child division</button>
              {{/unless}}
              <button class="button button--primary button--blue" type="submit">Save changes</button>
              <button class="button button--secondary button--dark-text" type="button" data-modal-close>Close</button>
            </div>
          </form>

          {{#unless (eq id "unit-root")}}
            {{#if canDelete}}
              <form class="modal-actions" action="{{../dashboardBasePath}}/admin/org-units/{{id}}/delete" method="post" data-confirm-message="Delete this division? Child divisions will move to the parent node.">
                <button class="button button--ghost" type="submit">Delete node</button>
              </form>
            {{/if}}
          {{/unless}}
        </section>
      </div>
    {{/each}}
  {{/if}}
</section>
{{/if}}

<section id="wallet-challenge-events" class="band band--light blade-panel" data-blade-panel="wallet-events">
  <div class="section-heading">
    <p class="eyebrow">Wallet events</p>
    <h2>Review organization wallet challenge events.</h2>
    <p>This page shows authentication, consent, promotion, approval, and revocation activity from the Aegis wallet flow.</p>
  </div>
  <article class="blade-guidance">
    <strong>Audit advice</strong>
    <span>Use wallet events for operational history. Use the app ledger when you need cross-application reporting for expenses, signatures, and other external systems.</span>
  </article>
  <div class="event-list">
    {{#each orgAdmin.events}}
      <details>
        <summary>{{title}} <span>{{createdAt}}</span></summary>
        <pre>{{details}}</pre>
      </details>
    {{/each}}
  </div>
</section>

{{#if orgAdmin.canManageAdminAssurance}}
<section id="admin-verification" class="band band--white blade-panel" data-blade-panel="admin-verification">
  <div class="section-heading">
    <p class="eyebrow">Admin verification</p>
    <h2>Validate administrator identity.</h2>
    <p>A wizard-style flow validates government photo ID, live face capture readiness, and profile assurance before admin deadlines expire.</p>
  </div>
  <article class="identity-reminder {{#if orgAdmin.adminProfile.isVerified}}identity-reminder--verified{{/if}}">
    <span class="platform-icon">IDV</span>
    <div>
      <strong>{{orgAdmin.adminProfile.verificationStatusLabel}}</strong>
      {{#if orgAdmin.adminProfile.isVerified}}
        <p>Last validated {{orgAdmin.adminProfile.lastValidatedLabel}}. Next profile validation is due {{orgAdmin.adminProfile.nextValidationDueLabel}} for security reasons.</p>
      {{else}}
        <p>Deadline: {{orgAdmin.adminProfile.verificationDeadlineLabel}}. Admins can keep working during the grace period, but production deployments should validate the original subscriber and co-admins.</p>
      {{/if}}
    </div>
    <div class="identity-reminder__actions">
      <button class="button button--primary button--blue" type="button" data-modal-target="#admin-identity-verification">{{#if orgAdmin.adminProfile.isVerified}}Re-validate{{else}}Start verification{{/if}}</button>
    </div>
  </article>
  <div class="policy-row">
    <article class="policy"><strong>1. Upload ID</strong><span>Capture or upload the government ID image and confirm document type.</span></article>
    <article class="policy"><strong>2. Live face capture</strong><span>Use webcam or front-facing camera until the face is centered and ready.</span></article>
    <article class="policy"><strong>3. Analysis</strong><span>Run matching and readiness checks, then mark the admin profile as validated.</span></article>
  </div>
</section>
{{/if}}

{{#if orgAdmin.isAdmin}}
<section id="workspace-settings" class="band band--white blade-panel" data-blade-panel="settings">
  <div class="section-heading">
    <p class="eyebrow">Settings</p>
    <h2>Workspace policy and lifecycle.</h2>
    <p>Manage organization-level defaults, evidence retention expectations, and lifecycle operations without mixing policy decisions into operational blades.</p>
  </div>
  <article class="blade-guidance">
    <strong>Policy advice</strong>
    <span>Keep invite expiry short by default, require wallet or passkey assurance for sensitive actions, and disable an organization before deleting it when audit history may still matter.</span>
  </article>
  <div class="configuration-grid">
    <article class="platform-card">
      <div class="platform-card__head">
        <span class="platform-icon">TTL</span>
        <div>
          <span class="track-label">Invitations</span>
          <h3>Default expiry</h3>
        </div>
      </div>
      <p>Current default: <strong>{{orgAdmin.orgPolicy.inviteTtlLabel}}</strong>. Admins can still override expiry during issuance.</p>
      <div class="platform-card__actions">
        <button class="button button--secondary button--dark-text" type="button" data-modal-target="#modal-policy-invite-expiry">Configure</button>
      </div>
    </article>
    <article class="platform-card">
      <div class="platform-card__head">
        <span class="platform-icon">IDV</span>
        <div>
          <span class="track-label">Profile validation</span>
          <h3>Re-validation cadence</h3>
        </div>
      </div>
      <p>Current cadence: <strong>{{orgAdmin.orgPolicy.adminRevalidationLabel}}</strong>. Admins can turn re-validation off for lab-only scenarios.</p>
      <div class="platform-card__actions">
        <button class="button button--secondary button--dark-text" type="button" data-modal-target="#modal-policy-admin-revalidation">Configure</button>
      </div>
    </article>
    <article class="platform-card">
      <div class="platform-card__head">
        <span class="platform-icon">RET</span>
        <div>
          <span class="track-label">Evidence</span>
          <h3>Ledger retention</h3>
        </div>
      </div>
      <p>Current retention: <strong>{{orgAdmin.orgPolicy.ledgerRetentionLabel}}</strong>. Keep logs long enough for audit, reporting, and evidence review.</p>
      <div class="platform-card__actions">
        <button class="button button--secondary button--dark-text" type="button" data-modal-target="#modal-policy-ledger-retention">Configure</button>
      </div>
    </article>
    <article class="platform-card">
      <div class="platform-card__head">
        <span class="platform-icon">RST</span>
        <div>
          <span class="track-label">Admin assurance</span>
          <h3>Reset validation</h3>
        </div>
      </div>
      <p>Clear profile validation for all organization users and require the next validation cycle to start over.</p>
      <div class="platform-card__actions">
        <button class="button button--ghost" type="button" data-modal-target="#modal-reset-all-validations">Reset All Users</button>
      </div>
    </article>
    <article class="platform-card">
      <div class="platform-card__head">
        <span class="platform-icon">ORG</span>
        <div>
          <span class="track-label">Lifecycle</span>
          <h3>Disable or delete</h3>
        </div>
      </div>
      <p>Disable the workspace to stop use while retaining history. Delete only after explicit administrative review.</p>
      <div class="platform-card__actions">
        {{#if workspace.isDisabled}}
          <form action="/organizations/{{subscription.id}}/{{workspace.id}}/enable" method="post">
            <button class="button button--primary button--blue" type="submit">Enable Organization</button>
          </form>
        {{else}}
          <form action="/organizations/{{subscription.id}}/{{workspace.id}}/disable" method="post">
            <button class="button button--secondary button--dark-text" type="submit">Disable Organization</button>
          </form>
        {{/if}}
        <form action="/organizations/{{subscription.id}}/{{workspace.id}}/delete" method="post">
          <button class="button button--ghost" type="submit">Delete Organization</button>
        </form>
      </div>
    </article>
  </div>

  <div class="app-modal" id="modal-policy-invite-expiry" hidden>
    <div class="app-modal__backdrop" data-modal-close></div>
    <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="modal-policy-invite-expiry-title">
      <div class="app-modal__head">
        <div>
          <p class="eyebrow">Invitation policy</p>
          <h2 id="modal-policy-invite-expiry-title">Change default invite expiry?</h2>
          <p>This updates the default expiry used when admins create new credential invitations.</p>
        </div>
        <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
      </div>
      <article class="note-panel note-panel--warning">
        <strong>Wallet challenge required</strong>
        <span>This policy change is recorded as an administrative wallet challenge event for audit history.</span>
      </article>
      <form class="wizard-form" action="{{dashboardBasePath}}/admin/policy" method="post">
        <input type="hidden" name="policyScope" value="invite-expiry">
        <div class="field-group">
          <label for="policyInviteTtlDays">Default invitation expiry in days</label>
          <input id="policyInviteTtlDays" name="inviteTtlDays" type="number" min="1" max="365" value="{{orgAdmin.orgPolicy.inviteTtlDays}}">
        </div>
        <div class="modal-actions">
          <button class="button button--primary button--blue" type="submit">Confirm Change</button>
          <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
        </div>
      </form>
    </section>
  </div>

  <div class="app-modal" id="modal-policy-admin-revalidation" hidden>
    <div class="app-modal__backdrop" data-modal-close></div>
    <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="modal-policy-admin-revalidation-title">
      <div class="app-modal__head">
        <div>
          <p class="eyebrow">Admin assurance</p>
          <h2 id="modal-policy-admin-revalidation-title">Configure profile re-validation?</h2>
          <p>Use this to control how often administrator identity profiles must be refreshed.</p>
        </div>
        <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
      </div>
      <article class="note-panel note-panel--warning">
        <strong>Wallet challenge required</strong>
        <span>Changing admin assurance policy affects every admin in this workspace and is written to the audit ledger.</span>
      </article>
      <form class="wizard-form" action="{{dashboardBasePath}}/admin/policy" method="post">
        <input type="hidden" name="policyScope" value="admin-revalidation">
        <label class="checkline">
          <input type="checkbox" name="adminRevalidationEnabled" value="yes" {{#if orgAdmin.orgPolicy.adminRevalidationEnabled}}checked{{/if}}>
          <span>Require periodic administrator re-validation</span>
        </label>
        <div class="field-group">
          <label for="policyAdminRevalidationMonths">Re-validation cadence in months</label>
          <input id="policyAdminRevalidationMonths" name="adminRevalidationMonths" type="number" min="1" max="36" value="{{orgAdmin.orgPolicy.adminRevalidationMonths}}">
        </div>
        <div class="modal-actions">
          <button class="button button--primary button--blue" type="submit">Confirm Change</button>
          <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
        </div>
      </form>
    </section>
  </div>

  <div class="app-modal" id="modal-policy-ledger-retention" hidden>
    <div class="app-modal__backdrop" data-modal-close></div>
    <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="modal-policy-ledger-retention-title">
      <div class="app-modal__head">
        <div>
          <p class="eyebrow">Ledger policy</p>
          <h2 id="modal-policy-ledger-retention-title">Change retention period?</h2>
          <p>This sets the expected evidence retention period for wallet challenge records.</p>
        </div>
        <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
      </div>
      <article class="note-panel note-panel--warning">
        <strong>Review legal and audit needs first</strong>
        <span>Reducing retention can affect reporting and evidence review. This change is recorded with a wallet challenge event.</span>
      </article>
      <form class="wizard-form" action="{{dashboardBasePath}}/admin/policy" method="post">
        <input type="hidden" name="policyScope" value="ledger-retention">
        <div class="field-group">
          <label for="policyLedgerRetentionDays">Ledger retention in days</label>
          <input id="policyLedgerRetentionDays" name="ledgerRetentionDays" type="number" min="30" max="3650" value="{{orgAdmin.orgPolicy.ledgerRetentionDays}}">
        </div>
        <div class="modal-actions">
          <button class="button button--primary button--blue" type="submit">Confirm Change</button>
          <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
        </div>
      </form>
    </section>
  </div>

  <div class="app-modal" id="modal-reset-all-validations" hidden>
    <div class="app-modal__backdrop" data-modal-close></div>
    <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="modal-reset-all-validations-title">
      <div class="app-modal__head">
        <div>
          <p class="eyebrow">Danger zone</p>
          <h2 id="modal-reset-all-validations-title">Reset validation for all users?</h2>
          <p>Every administrator and credential holder in this workspace will be marked as needing profile validation again.</p>
        </div>
        <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
      </div>
      <article class="note-panel note-panel--danger">
        <strong>This cannot be silently undone</strong>
        <span>Confirming sends an administrative wallet challenge, records an audit event, and clears the current profile validation state for all users in this organization.</span>
      </article>
      <form class="modal-actions" action="{{dashboardBasePath}}/admin/profile-validations/reset-all" method="post">
        <button class="button button--ghost" type="submit">Reset All Validations</button>
        <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
      </form>
    </section>
  </div>
</section>
{{/if}}

<section id="external-wallet-ledger" class="band band--light blade-panel" data-blade-panel="ledger">
  <div class="section-heading">
    <p class="eyebrow">External app ledger</p>
    <h2>High-assurance wallet challenges from connected applications.</h2>
    <p>Authentication, approvals, rejections, and contract-style decisions are captured here with immutable wallet payloads for organization reporting.</p>
  </div>
  <article class="blade-guidance">
    <strong>Why this matters</strong>
    <span>{{#if orgAdmin.canViewOrgLedger}}Use the ledger to prove who approved, rejected, authenticated, or consented to an action, with the original payload retained for reporting and audit.{{else}}Your ledger view is scoped to wallet challenges associated with your credential in this organization.{{/if}}</span>
  </article>

  <div class="people-directory">
    <div class="people-directory__head">
      <div>
        <p class="eyebrow">Reporting</p>
        <h3>Recent wallet-signed actions</h3>
        <p>These records are created by apps such as Business Expenses when they request a wallet signature.</p>
      </div>
      <a class="button button--secondary button--dark-text" href="#issuer-orgs">Connect issuing org</a>
    </div>

    {{#if hasWalletChallengeLedger}}
      <div class="people-table-wrap">
        <table class="people-table">
          <thead>
            <tr>
              <th>Application</th>
              <th>Subject</th>
              <th>Action</th>
              <th>Resource</th>
              <th>Status</th>
              <th>Timestamp</th>
              <th>Payload</th>
            </tr>
          </thead>
          <tbody>
            {{#each walletChallengeLedger}}
              <tr>
                <td>{{appName}}</td>
                <td>{{subject}}</td>
                <td>{{action}}</td>
                <td>{{resourceType}} {{resourceId}}</td>
                <td><span class="status-pill status-pill--{{status}}">{{status}}</span></td>
                <td>{{createdAt}}</td>
                <td>
                  <details>
                    <summary>{{challengeId}}</summary>
                    <dl class="claim-list">
                      {{#each payloadFields}}
                        <div>
                          <dt>{{key}}</dt>
                          <dd>{{value}}</dd>
                        </div>
                      {{/each}}
                    </dl>
                  </details>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <article class="note-panel">
        <strong>No external wallet challenge records yet.</strong>
        <span>Run the Business Expenses example, sign in with Aegis ID, then approve or reject an expense with the iOS wallet.</span>
      </article>
    {{/if}}
  </div>
</section>

<section id="roles-management" class="band band--light blade-panel" data-blade-panel="roles">
  <div class="section-heading">
    <p class="eyebrow">Roles</p>
    <h2>Define authorization roles.</h2>
    <p>Roles control what a credential holder can do inside the organization and connected applications.</p>
  </div>
  <article class="blade-guidance">
    <strong>Role design advice</strong>
    <span>Only mark a role as administrative when it should unlock management menus and high-risk actions. For non-admin roles, grant only the exact privileges required for the workflow.</span>
  </article>
  {{#if orgAdmin.canViewRoles}}
    <div class="people-directory configuration-table-panel" data-tour-anchor="configure">
      <div class="people-directory__head">
        <div>
          <p class="eyebrow">Access model</p>
          <h3>Role definitions</h3>
          <p>{{orgAdmin.roles.length}} role definitions available for credential assignment.</p>
        </div>
        {{#if orgAdmin.canManageRoles}}
          <div class="people-directory__tools">
            <button class="button button--primary button--blue" type="button" data-modal-target="#modal-add-role">Add Role</button>
          </div>
        {{/if}}
      </div>
      <div class="people-table-wrap">
        <table class="people-table definition-table">
          <thead>
            <tr>
              <th>Role</th>
              <th>Purpose</th>
              <th>Type</th>
              <th>Privileges</th>
              {{#if orgAdmin.canManageRoles}}<th>Actions</th>{{/if}}
            </tr>
          </thead>
          <tbody>
            {{#each orgAdmin.roles}}
              <tr>
                <td><strong>{{name}}</strong></td>
                <td>{{description}}</td>
                <td><span class="status-pill {{#if adminRole}}status-pill--active{{else}}status-pill--invited{{/if}}">{{adminRoleLabel}}</span></td>
                <td><strong>{{privilegeCount}}</strong><br><span class="table-muted">{{privilegeSummary}}</span></td>
                {{#if ../orgAdmin.canManageRoles}}
                  <td>
                    <div class="row-actions">
                      <button class="icon-button" type="button" data-modal-target="#role-edit-{{id}}">Edit</button>
                      <button class="icon-button icon-button--danger" type="button" data-modal-target="#role-delete-{{id}}">Revoke</button>
                    </div>
                  </td>
                {{/if}}
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  {{/if}}
</section>

<section id="claims-management" class="band band--light blade-panel" data-blade-panel="claims">
  <div class="section-heading">
    <p class="eyebrow">Claims</p>
    <h2>Control what credentials can carry.</h2>
    <p>Claim definitions become reusable fields for issuance, presentation policies, consent prompts, and delta requests.</p>
  </div>
  <article class="blade-guidance">
    <strong>Claim design advice</strong>
    <span>Use claims for facts about a person, such as department, employee status, or assurance level. Only request sensitive data when the user has a clear consent reason.</span>
  </article>
  {{#if orgAdmin.canViewClaims}}
    <div class="people-directory configuration-table-panel">
      <div class="people-directory__head">
        <div>
          <p class="eyebrow">Consent data</p>
          <h3>Claim definitions</h3>
          <p>{{orgAdmin.claimDefinitions.length}} claim definitions available for issue and wallet consent.</p>
        </div>
        {{#if orgAdmin.canManageClaims}}
          <div class="people-directory__tools">
            <button class="button button--primary button--blue" type="button" data-modal-target="#modal-add-claim">Add Claim</button>
          </div>
        {{/if}}
      </div>
      <div class="people-table-wrap">
        <table class="people-table definition-table">
          <thead>
            <tr>
              <th>Claim</th>
              <th>Key</th>
              <th>Type</th>
              <th>Required</th>
              <th>Default</th>
              {{#if orgAdmin.canManageClaims}}<th>Actions</th>{{/if}}
            </tr>
          </thead>
          <tbody>
            {{#each orgAdmin.claimDefinitions}}
              <tr>
                <td><strong>{{label}}</strong></td>
                <td><code>{{key}}</code></td>
                <td>{{type}}</td>
                <td>
                  {{#if required}}
                    <span class="status-pill status-pill--active">Required</span>
                  {{else}}
                    <span class="status-pill status-pill--invited">Optional</span>
                  {{/if}}
                </td>
                <td>{{#if defaultValue}}{{defaultValue}}{{else}}<span class="table-muted">None</span>{{/if}}</td>
                {{#if ../orgAdmin.canManageClaims}}
                  <td>
                    <div class="row-actions">
                      <button class="icon-button" type="button" data-modal-target="#claim-edit-{{id}}">Edit</button>
                      <button class="icon-button icon-button--danger" type="button" data-modal-target="#claim-delete-{{id}}">Revoke</button>
                    </div>
                  </td>
                {{/if}}
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  {{/if}}
</section>

<div class="workspace-modal-stack">
  {{#if orgAdmin.canManageConfiguration}}
    <div class="app-modal" id="modal-add-role" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="add-role-title">
        <div class="app-modal__head">
          <div>
            <p class="eyebrow">Role</p>
            <h2 id="add-role-title">Add role</h2>
          </div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/roles" method="post">
          <div class="field-group">
            <label class="field-label" for="roleName">Role name <span class="field-tooltip" tabindex="0" data-tooltip="A short privilege label that can be assigned to one or more credential holders.">?</span></label>
            <input id="roleName" name="name" type="text" required>
          </div>
          <div class="field-group">
            <label for="roleDescription">Description</label>
            <textarea id="roleDescription" name="description" rows="3"></textarea>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label class="field-label" for="roleTemplate">Privilege template <span class="field-tooltip" tabindex="0" data-tooltip="Start from a practical role pattern, then adjust individual privileges below.">?</span></label>
              <select id="roleTemplate" name="privilegeTemplate" data-role-template-select>
                <option value="">Choose exact privileges below</option>
                {{#each orgAdmin.roleTemplates}}
                  <option value="{{id}}" data-admin-role="{{adminRoleValue}}" data-privileges="{{privilegeCsv}}">{{name}}</option>
                {{/each}}
              </select>
            </div>
            <label class="checkline checkline--strong">
              <input name="adminRole" type="checkbox" value="yes">
              <span>Administrative role</span>
            </label>
          </div>
          <article class="note-panel">
            <strong>Role design advice</strong>
            <span>Use administrative roles only for people who should manage the organization. For non-admin roles, grant only the exact privileges needed for the workflow, such as ledger review or credential issuance.</span>
          </article>
          <div class="privilege-groups">
            {{#each orgAdmin.privilegeGroups}}
              <fieldset>
                <legend>{{name}}</legend>
                <p>{{description}}</p>
                <div class="checkbox-grid">
                  {{#each privileges}}
                    <label class="checkline">
                      <input type="checkbox" name="privilegeIds" value="{{id}}" {{#if checked}}checked{{/if}}>
                      <span><strong>{{name}}</strong><small>{{description}}</small></span>
                    </label>
                  {{/each}}
                </div>
              </fieldset>
            {{/each}}
          </div>
          <div class="modal-actions">
            <button class="button button--primary button--blue" type="submit">Create Role</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>
    </div>

    <div class="app-modal" id="modal-add-claim" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="add-claim-title">
        <div class="app-modal__head">
          <div>
            <p class="eyebrow">Claim</p>
            <h2 id="add-claim-title">Add claim</h2>
          </div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/claims" method="post">
          <div class="field-row">
            <div class="field-group">
              <label class="field-label" for="claimLabel">Claim label <span class="field-tooltip" tabindex="0" data-tooltip="Human-readable label shown in admin forms and wallet context.">?</span></label>
              <input id="claimLabel" name="label" type="text" required>
            </div>
            <div class="field-group">
              <label class="field-label" for="claimKey">Claim key <span class="field-tooltip" tabindex="0" data-tooltip="Stable machine-readable key. Use letters, numbers, or underscore.">?</span></label>
              <input id="claimKey" name="key" type="text" required>
            </div>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label for="claimType">Type</label>
              <select id="claimType" name="type">
