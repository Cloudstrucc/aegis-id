                <option value="email">Email</option>
                <option value="number">Number</option>
                <option value="date">Date</option>
              </select>
            </div>
            <div class="field-group">
              <label for="claimDefault">Default value</label>
              <input id="claimDefault" name="defaultValue" type="text">
            </div>
          </div>
          <label class="checkline">
            <input name="required" type="checkbox" value="yes">
            <span>Required claim</span>
          </label>
          <div class="modal-actions">
            <button class="button button--primary button--blue" type="submit">Create Claim</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>
    </div>

    {{#each orgAdmin.roles}}
      <div class="app-modal" id="role-edit-{{id}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="role-edit-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">Role</p>
              <h2 id="role-edit-title-{{id}}">Edit {{name}}</h2>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>
          <form class="wizard-form" action="{{../dashboardBasePath}}/admin/roles/{{id}}/update" method="post">
            <div class="field-group">
              <label for="role-name-{{id}}">Role name</label>
              <input id="role-name-{{id}}" name="name" type="text" value="{{name}}" required>
            </div>
            <div class="field-group">
              <label for="role-description-{{id}}">Description</label>
              <textarea id="role-description-{{id}}" name="description" rows="3">{{description}}</textarea>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="role-template-{{id}}">Privilege template</label>
                <select id="role-template-{{id}}" name="privilegeTemplate" data-role-template-select>
                  <option value="">Keep current privileges</option>
                  {{#each ../orgAdmin.roleTemplates}}
                    <option value="{{id}}" data-admin-role="{{adminRoleValue}}" data-privileges="{{privilegeCsv}}">{{name}}</option>
                  {{/each}}
                </select>
              </div>
              <label class="checkline checkline--strong">
                <input name="adminRole" type="checkbox" value="yes" {{#if adminRole}}checked{{/if}}>
                <span>Administrative role</span>
              </label>
            </div>
            <article class="note-panel">
              <strong>{{adminRoleLabel}}</strong>
              <span>{{privilegeSummary}}. Administrative roles should be paired with wallet challenge approval for assignment and revocation.</span>
            </article>
            <div class="privilege-groups">
              {{#each privilegeGroups}}
                <fieldset>
                  <legend>{{name}}</legend>
                  <p>{{description}}</p>
                  <div class="checkbox-grid">
                    {{#each privileges}}
                      <label class="checkline">
                        <input type="checkbox" name="privilegeIds" value="{{id}}" {{#if checked}}checked{{/if}}>
                        <span><strong>{{name}}</strong><small>{{description}}</small></span>
                      </label>
                    {{/each}}
                  </div>
                </fieldset>
              {{/each}}
            </div>
            <div class="modal-actions">
              <button class="button button--primary button--blue" type="submit">Save Role</button>
              <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
            </div>
          </form>
        </section>
      </div>
      <div class="app-modal" id="role-delete-{{id}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="role-delete-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">Confirm role revoke</p>
              <h2 id="role-delete-title-{{id}}">Revoke {{name}}?</h2>
              <p>This removes the role from future choices and from assigned credentials.</p>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>
          <form class="modal-actions" action="{{../dashboardBasePath}}/admin/roles/{{id}}/delete" method="post">
            <button class="button button--ghost" type="submit">Revoke Role</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </form>
        </section>
      </div>
    {{/each}}

    {{#each orgAdmin.claimDefinitions}}
      <div class="app-modal" id="claim-edit-{{id}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="claim-edit-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">Claim</p>
              <h2 id="claim-edit-title-{{id}}">Edit {{label}}</h2>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>
          <form class="wizard-form" action="{{../dashboardBasePath}}/admin/claims/{{id}}/update" method="post">
            <div class="field-row">
              <div class="field-group">
                <label for="claim-label-{{id}}">Claim label</label>
                <input id="claim-label-{{id}}" name="label" type="text" value="{{label}}" required>
              </div>
              <div class="field-group">
                <label for="claim-key-{{id}}">Claim key</label>
                <input id="claim-key-{{id}}" name="key" type="text" value="{{key}}" required>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="claim-type-{{id}}">Type</label>
                <select id="claim-type-{{id}}" name="type">
                  <option value="text" {{#if (eq type "text")}}selected{{/if}}>Text</option>
                  <option value="email" {{#if (eq type "email")}}selected{{/if}}>Email</option>
                  <option value="number" {{#if (eq type "number")}}selected{{/if}}>Number</option>
                  <option value="date" {{#if (eq type "date")}}selected{{/if}}>Date</option>
                </select>
              </div>
              <div class="field-group">
                <label for="claim-default-{{id}}">Default value</label>
                <input id="claim-default-{{id}}" name="defaultValue" type="text" value="{{defaultValue}}">
              </div>
            </div>
            <label class="checkline">
              <input name="required" type="checkbox" value="yes" {{#if required}}checked{{/if}}>
              <span>Required claim</span>
            </label>
            <div class="modal-actions">
              <button class="button button--primary button--blue" type="submit">Save Claim</button>
              <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
            </div>
          </form>
        </section>
      </div>
      <div class="app-modal" id="claim-delete-{{id}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="claim-delete-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">Confirm claim revoke</p>
              <h2 id="claim-delete-title-{{id}}">Revoke {{label}}?</h2>
              <p>This removes the claim from credential templates and existing profile values.</p>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>
          <form class="modal-actions" action="{{../dashboardBasePath}}/admin/claims/{{id}}/delete" method="post">
            <button class="button button--ghost" type="submit">Revoke Claim</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </form>
        </section>
      </div>
    {{/each}}
  {{/if}}
</div>

<section id="org-branding" class="band band--white blade-panel" data-blade-panel="branding">
  <div class="section-heading">
    <p class="eyebrow">Organization branding</p>
    <h2>Control the wallet context for this org.</h2>
    <p>Choose a palette or upload a small logo. The org profile API exposes this branding to the iOS wallet when it is viewing this organization context.</p>
  </div>
  <article class="blade-guidance">
    <strong>Advice</strong>
    <span>Branding helps holders recognize which organization is asking for consent or approval. Keep palettes high-contrast and consistent with the issuer’s public identity.</span>
  </article>
  <div class="admin-grid">
    <article class="brand-preview-card" style="--brand-primary: {{orgAdmin.branding.primaryColor}}; --brand-accent: {{orgAdmin.branding.accentColor}}; --brand-bg: {{orgAdmin.branding.backgroundColor}}; --brand-text: {{orgAdmin.branding.textColor}};">
      {{#if orgAdmin.branding.logoDataUrl}}
        <img src="{{orgAdmin.branding.logoDataUrl}}" alt="{{workspace.organization}} logo">
      {{else}}
        <span>V</span>
      {{/if}}
      <h3>{{workspace.organization}}</h3>
      <p>Aegis ID wallet profile</p>
    </article>

    {{#if orgAdmin.canManageBranding}}
      <form class="platform-card wizard-form" action="{{dashboardBasePath}}/admin/branding" method="post">
        <div class="field-group">
          <label for="paletteId">Palette</label>
          <select id="paletteId" name="paletteId">
            {{#each orgAdmin.palettes}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
            {{/each}}
            <option value="custom" {{#if orgAdmin.customPaletteSelected}}selected{{/if}}>Custom palette</option>
          </select>
        </div>
        <div class="field-row">
          <div class="field-group">
            <label for="primaryColor">Primary</label>
            <input id="primaryColor" name="primaryColor" type="color" value="{{orgAdmin.branding.primaryColor}}">
          </div>
          <div class="field-group">
            <label for="accentColor">Accent</label>
            <input id="accentColor" name="accentColor" type="color" value="{{orgAdmin.branding.accentColor}}">
          </div>
        </div>
        <div class="field-row">
          <div class="field-group">
            <label for="backgroundColor">Background</label>
            <input id="backgroundColor" name="backgroundColor" type="color" value="{{orgAdmin.branding.backgroundColor}}">
          </div>
          <div class="field-group">
            <label for="textColor">Text</label>
            <input id="textColor" name="textColor" type="color" value="{{orgAdmin.branding.textColor}}">
          </div>
        </div>
        <div class="field-group">
          <label for="logoUpload">Logo upload</label>
          <input id="logoUpload" type="file" accept="image/png,image/jpeg,image/webp" data-logo-upload>
          <input type="hidden" name="logoDataUrl" data-logo-data-url>
        </div>
        <button class="button button--primary button--blue" type="submit">Save Branding</button>
      </form>
    {{/if}}
  </div>
</section>

<section id="issuer-orgs" class="band band--white blade-panel" data-blade-panel="issuer-orgs">
  <div class="section-heading">
    <p class="eyebrow">Issuing organization</p>
    <h2>Create the org credential invitation used by the wallet challenge.</h2>
    <p>The OIDC wallet test can send a challenge from any org that has an accepted issuer connection.</p>
  </div>
  <article class="blade-guidance">
    <strong>Next step</strong>
    <span>Create one issuer invitation per organization context, scan it from the Vanguard Aegis ID mobile app, then use that connected org as the challenge sender for OIDC and example app demos.</span>
  </article>

  <div class="issuer-org-layout">
    <article class="platform-card">
      <div class="platform-card__head">
        <span class="platform-icon">ORG</span>
        <div>
          <span class="track-label">Subscriber org</span>
          <h3>{{workspace.organization}}</h3>
        </div>
      </div>
      <p>Create an Aries issuer invitation branded to this organization. After the iOS wallet accepts it, the org appears as a selectable challenge sender in the OIDC wallet demo.</p>
      {{#if orgAdmin.canManageIntegrations}}
        <form action="{{dashboardBasePath}}/issuer-organizations/invitations" method="post">
          <button class="button button--primary button--blue" type="submit">Create Org Issuer Invitation</button>
        </form>
      {{else}}
        <article class="note-panel">
          <strong>Integration setup requires additional privileges.</strong>
          <span>You can review issuer status, but creating new invitations is limited to integration administrators.</span>
        </article>
      {{/if}}
    </article>

    {{#if hasIssuerOrganizations}}
      {{#each issuerOrganizations}}
        <article class="demo-qr-card">
          <p class="eyebrow">{{status}}</p>
          <h3>{{organizationName}}</h3>
          <p class="demo-qr-card__description">Scan with the Vanguard Aegis ID wallet, accept the invitation, then fetch OIDC challenges from this issuer connection.</p>
          {{#if iosQrCodeDataUrl}}
            <img class="demo-qr-card__image" src="{{iosQrCodeDataUrl}}" alt="{{organizationName}} issuer invitation QR code">
          {{/if}}
          <code class="demo-qr-card__url">{{iosDeepLinkUrl}}</code>
          <dl class="claim-list">
            <div>
              <dt>Status</dt>
              <dd>{{status}}</dd>
            </div>
            <div>
              <dt>Issuer connection</dt>
              <dd>{{#if issuerConnectionId}}{{issuerConnectionId}}{{else}}Waiting for wallet acceptance{{/if}}</dd>
            </div>
            <div>
              <dt>Invitation</dt>
              <dd>{{invitationId}}</dd>
            </div>
          </dl>
        </article>
      {{/each}}
    {{else}}
      <article class="note-panel">
        <strong>No org issuer invitations yet.</strong>
        <span>Create an invitation, then accept it in the iOS wallet to make this org available for OIDC wallet challenges.</span>
      </article>
    {{/if}}
  </div>
</section>

{{#if orgAdmin.canViewConnectedApps}}
<section id="connected-apps" class="band band--white blade-panel" data-blade-panel="connected-apps">
  <div class="section-heading">
    <p class="eyebrow">Connected apps</p>
    <h2>Register relying-party applications.</h2>
    <p>Use this blade when another web app, mobile app, API, or workflow needs Aegis ID for OIDC sign-in, OAuth client credentials, or wallet challenge APIs.</p>
  </div>

  <article class="blade-guidance">
    <strong>Developer path</strong>
    <span>Create an app registration, copy the discovery URL into the relying party, issue a one-time secret or import a certificate, then use the API logs and wallet ledger to audit every request.</span>
  </article>

  <div class="dashboard-summary dashboard-summary--four">
    <article><span class="metric">{{connectedApps.stats.total}}</span><p>Connected apps</p></article>
    <article><span class="metric">{{connectedApps.stats.enabled}}</span><p>Enabled clients</p></article>
    <article><span class="metric">{{connectedApps.stats.secrets}}</span><p>Active secrets</p></article>
    <article><span class="metric">{{connectedApps.stats.certificates}}</span><p>Certificate credentials</p></article>
  </div>

  <article class="people-directory connected-app-directory">
    <div class="people-directory__head">
      <div>
        <p class="eyebrow">App registrations</p>
        <h3>Connected applications</h3>
        <p>{{connectedApps.table.total}} registrations shown. Configure OIDC/OAuth, credentials, logs, and wallet challenge APIs from each row.</p>
      </div>
      {{#if orgAdmin.canManageConnectedApps}}
        <button class="button button--primary button--blue connected-app-create-button" type="button" data-modal-target="#modal-connected-app-create">Create registration</button>
      {{/if}}
    </div>

    <form class="people-filters connected-app-filters" method="get" action="{{dashboardBasePath}}">
      <input name="connectedAppSearch" type="search" value="{{connectedApps.table.search}}" placeholder="Search apps, client IDs, owners">
      <select name="connectedAppStatus">
        <option value="">All statuses</option>
        <option value="enabled" {{#if (eq connectedApps.table.status "enabled")}}selected{{/if}}>Enabled</option>
        <option value="disabled" {{#if (eq connectedApps.table.status "disabled")}}selected{{/if}}>Disabled</option>
      </select>
      <select name="connectedAppType">
        <option value="">All app types</option>
        {{#each connectedApps.table.appTypes}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{value}}</option>
        {{/each}}
      </select>
      <select name="connectedAppSort">
        {{#each connectedApps.table.sortOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
      <select name="connectedAppDirection">
        {{#each connectedApps.table.directionOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
      <button class="button button--secondary button--dark-text" type="submit">Apply</button>
    </form>

    <div class="people-table-wrap connected-app-table-wrap">
      <table class="people-table connected-app-table">
        <thead>
          <tr>
            <th>Application</th>
            <th>Client ID</th>
            <th>Type</th>
            <th>Status</th>
            <th>Auth method</th>
            <th>Credentials</th>
            <th>Updated</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each connectedApps.table.rows}}
            <tr>
              <td>
                <strong>{{name}}</strong>
                <span>{{description}}</span>
              </td>
              <td><code>{{clientId}}</code></td>
              <td>{{appType}}</td>
              <td><span class="status-pill status-pill--{{status}}">{{statusLabel}}</span></td>
              <td>{{tokenEndpointAuthMethod}}</td>
              <td>{{activeSecretCount}} secrets · {{activeCertificateCount}} certs</td>
              <td>{{updatedAt}}</td>
              <td>
                <div class="row-actions">
                  <button class="icon-button" type="button" data-modal-target="#modal-connected-app-{{id}}">Edit</button>
                  {{#if ../orgAdmin.canManageConnectedApps}}
                    <form method="post" action="{{../dashboardBasePath}}/admin/connected-apps/{{id}}/status" data-confirm-message="{{nextStatusLabel}} this connected app?">
                      <input type="hidden" name="status" value="{{nextStatus}}">
                      <button class="icon-button" type="submit">{{nextStatusLabel}}</button>
                    </form>
                    <form method="post" action="{{../dashboardBasePath}}/admin/connected-apps/{{id}}/delete" data-confirm-message="Delete this connected app registration? OAuth and API calls for this client will stop working.">
                      <button class="icon-button icon-button--danger" type="submit">Delete</button>
                    </form>
                  {{/if}}
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
      {{#unless connectedApps.table.hasRows}}
        <p class="empty-table-note">No connected apps match this filter yet.</p>
      {{/unless}}
    </div>

    <form class="people-pagination" method="get" action="{{dashboardBasePath}}">
      <input type="hidden" name="connectedAppSearch" value="{{connectedApps.table.search}}">
      <input type="hidden" name="connectedAppStatus" value="{{connectedApps.table.status}}">
      <input type="hidden" name="connectedAppType" value="{{connectedApps.table.appType}}">
      <input type="hidden" name="connectedAppSort" value="{{connectedApps.table.sort}}">
      <input type="hidden" name="connectedAppDirection" value="{{connectedApps.table.direction}}">
      {{#if connectedApps.table.hasPrevious}}
        <button class="button button--secondary button--dark-text" name="connectedAppPage" value="{{connectedApps.table.previousPage}}" type="submit">Previous</button>
      {{/if}}
      <span>Page {{connectedApps.table.page}} of {{connectedApps.table.totalPages}}</span>
      {{#if connectedApps.table.hasNext}}
        <button class="button button--secondary button--dark-text" name="connectedAppPage" value="{{connectedApps.table.nextPage}}" type="submit">Next</button>
      {{/if}}
    </form>
  </article>

  {{#each connectedApps.table.rows}}
    <div class="app-modal" id="modal-connected-app-{{id}}" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel app-modal__panel--xwide connected-app-modal" role="dialog" aria-modal="true" aria-labelledby="connected-app-title-{{id}}">
        <div class="app-modal__head">
          <div>
            <p class="eyebrow">Connected app</p>
            <h2 id="connected-app-title-{{id}}">{{name}}</h2>
            <p>{{clientId}}</p>
          </div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>

        {{#if ../connectedApps.secretCreated}}
          {{#if (eq ../connectedApps.secretCreated.appId id)}}
            <article class="secret-callout">
              <strong>Copy this client secret now</strong>
              <span>It is encrypted for two-minute reveal workflows, but this is the only time it is shown without a wallet challenge.</span>
              <code>{{../connectedApps.secretCreated.value}}</code>
              <small>Expires {{../connectedApps.secretCreated.expiresAt}}</small>
            </article>
          {{/if}}
        {{/if}}

        <dl class="claim-list connected-app-endpoints">
          <div><dt>Discovery</dt><dd><code>{{discoveryUrl}}</code></dd></div>
          <div><dt>Authorization</dt><dd><code>{{authorizationEndpoint}}</code></dd></div>
          <div><dt>Token</dt><dd><code>{{tokenEndpoint}}</code></dd></div>
          <div><dt>Wallet challenge API</dt><dd><code>{{walletChallengeEndpoint}}</code></dd></div>
        </dl>

        {{#if ../orgAdmin.canManageConnectedApps}}
          <form class="wizard-form connected-app-form connected-app-form--full" method="post" action="{{../dashboardBasePath}}/admin/connected-apps/{{id}}/update">
            <div class="field-row">
              <div class="field-group">
                <label for="connected-app-name-{{id}}">App name</label>
                <input id="connected-app-name-{{id}}" name="name" type="text" value="{{name}}" required>
              </div>
              <div class="field-group">
                <label for="connected-app-status-{{id}}">Status</label>
                <select id="connected-app-status-{{id}}" name="status">
                  <option value="enabled" {{#if (eq status "enabled")}}selected{{/if}}>Enabled</option>
                  <option value="disabled" {{#if (eq status "disabled")}}selected{{/if}}>Disabled</option>
                </select>
              </div>
              <div class="field-group">
                <label for="connected-app-type-{{id}}">App type</label>
                <input id="connected-app-type-{{id}}" name="appType" type="text" value="{{appType}}">
              </div>
              <div class="field-group">
                <label for="connected-app-onboarding-{{id}}">Registration mode</label>
                <select id="connected-app-onboarding-{{id}}" name="onboardingMode">
                  <option value="invite-only" {{#if (eq onboardingMode "invite-only")}}selected{{/if}}>Invite only</option>
                  <option value="open" {{#if (eq onboardingMode "open")}}selected{{/if}}>Open registration</option>
                </select>
              </div>
            </div>
            <div class="field-group">
              <label for="connected-app-description-{{id}}">Description</label>
              <textarea id="connected-app-description-{{id}}" name="description" rows="3">{{description}}</textarea>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="connected-app-redirects-{{id}}">Callback URIs</label>
                <textarea id="connected-app-redirects-{{id}}" name="redirectUris" rows="4">{{redirectUrisText}}</textarea>
              </div>
              <div class="field-group">
                <label for="connected-app-origins-{{id}}">Allowed origins</label>
                <textarea id="connected-app-origins-{{id}}" name="allowedOrigins" rows="4">{{allowedOriginsText}}</textarea>
              </div>
              <div class="field-group">
                <label for="connected-app-logout-{{id}}">Post logout redirect URIs</label>
                <textarea id="connected-app-logout-{{id}}" name="postLogoutRedirectUris" rows="4">{{postLogoutRedirectUrisText}}</textarea>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="connected-app-grants-{{id}}">Grant types</label>
                <input id="connected-app-grants-{{id}}" name="grantTypes" type="text" value="{{grantTypesRawText}}">
              </div>
              <div class="field-group">
                <label for="connected-app-scopes-{{id}}">Scopes</label>
                <input id="connected-app-scopes-{{id}}" name="scopes" type="text" value="{{scopesText}}">
              </div>
              <div class="field-group">
                <label for="connected-app-claims-{{id}}">JWT claims</label>
                <input id="connected-app-claims-{{id}}" name="claimKeys" type="text" value="{{claimKeysText}}">
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="connected-app-token-auth-{{id}}">Token auth method</label>
                <select id="connected-app-token-auth-{{id}}" name="tokenEndpointAuthMethod">
                  <option value="client_secret_post" {{#if (eq tokenEndpointAuthMethod "client_secret_post")}}selected{{/if}}>Client secret post</option>
                  <option value="client_secret_basic" {{#if (eq tokenEndpointAuthMethod "client_secret_basic")}}selected{{/if}}>Client secret basic</option>
                  <option value="private_key_jwt" {{#if (eq tokenEndpointAuthMethod "private_key_jwt")}}selected{{/if}}>Certificate / private key JWT</option>
                </select>
              </div>
              <div class="field-group">
                <label for="connected-app-policy-{{id}}">Wallet challenge assurance</label>
                <select id="connected-app-policy-{{id}}" name="walletChallengePolicy">
                  <option value="wallet" {{#if (eq walletChallengePolicy "wallet")}}selected{{/if}}>Wallet approval</option>
                  <option value="passkey" {{#if (eq walletChallengePolicy "passkey")}}selected{{/if}}>Wallet plus passkey</option>
                  <option value="verified-id" {{#if (eq walletChallengePolicy "verified-id")}}selected{{/if}}>Verified credential</option>
                </select>
              </div>
              <div class="field-group">
                <label for="connected-app-logo-{{id}}">Sign-in logo URL</label>
                <input id="connected-app-logo-{{id}}" name="logoUrl" type="url" value="{{branding.logoUrl}}">
              </div>
            </div>
            <div class="modal-actions">
              <button class="button button--primary button--blue" type="submit">Save connected app</button>
              <a class="button button--secondary button--dark-text" href="/developer/api">API docs</a>
            </div>
          </form>
        {{/if}}

        <div class="connected-app-modal-grid">
          <article class="connected-app-card connected-app-card--table">
            <div class="connected-app-card__head">
              <div><p class="eyebrow">Secrets</p><h3>Client secrets</h3></div>
              {{#if ../orgAdmin.canManageConnectedAppCredentials}}
                <button class="button button--secondary button--dark-text" type="button" data-modal-target="#modal-connected-app-secret-{{id}}" {{#unless canCreateSecret}}disabled{{/unless}}>Create secret</button>
              {{/if}}
            </div>
            <div class="table-wrap">
              <table class="workspace-table connected-app-subtable">
                <thead><tr><th>Label</th><th>Secret</th><th>Expires</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                  {{#each secretCredentials}}
                    <tr>
                      <td>{{label}}</td>
                      <td>
                        {{#if revealedValue}}
                          <code>{{revealedValue}}</code>
                          <small class="table-hint">Shown temporarily for this session.</small>
                        {{else}}
                          <code>{{maskedValue}}</code>
                          {{#if revealPending}}<small class="table-hint">Wallet challenge pending. Accept in the wallet, then press View again.</small>{{/if}}
                        {{/if}}
                      </td>
                      <td>{{expiresAt}}</td>
                      <td>{{#if revokedAt}}Revoked{{else}}{{#if expired}}Expired{{else}}Active{{/if}}{{/if}}</td>
                      <td>
                        <div class="row-actions">
                          {{#if ../../orgAdmin.canManageConnectedAppCredentials}}
                            {{#unless revokedAt}}
                              {{#if canReveal}}
                                <form method="post" action="{{../../dashboardBasePath}}/admin/connected-apps/{{../id}}/secrets/{{id}}/reveal" data-confirm-message="Request a wallet challenge to reveal this secret for two minutes?">
                                  <button class="icon-button" type="submit" title="Reveal secret">View</button>
                                </form>
                              {{else}}
                                <span class="status-pill">Rotate to reveal</span>
                              {{/if}}
                              <form method="post" action="{{../../dashboardBasePath}}/admin/connected-apps/{{../id}}/secrets/{{id}}/revoke" data-confirm-message="Revoke this client secret?">
                                <button class="icon-button icon-button--danger" type="submit">Revoke</button>
                              </form>
                            {{/unless}}
                          {{/if}}
                        </div>
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          </article>

          <article class="connected-app-card connected-app-card--table">
            <div class="connected-app-card__head">
              <div><p class="eyebrow">Certificates</p><h3>Certificate credentials</h3></div>
              {{#if ../orgAdmin.canManageConnectedAppCredentials}}
                <button class="button button--secondary button--dark-text" type="button" data-modal-target="#modal-connected-app-certificate-{{id}}" {{#unless canCreateCertificate}}disabled{{/unless}}>Create certificate</button>
              {{/if}}
            </div>
            <div class="table-wrap">
              <table class="workspace-table connected-app-subtable">
                <thead><tr><th>Label</th><th>Fingerprint</th><th>Expires</th><th>Status</th></tr></thead>
                <tbody>
                  {{#each certificateCredentials}}
                    <tr>
                      <td>{{label}}</td>
                      <td><code>{{displayFingerprint}}</code></td>
                      <td>{{#if expiresAt}}{{expiresAt}}{{else}}No expiry set{{/if}}</td>
                      <td>{{#if revokedAt}}Revoked{{else}}{{#if expired}}Expired{{else}}Active{{/if}}{{/if}}</td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          </article>

          <article class="connected-app-card connected-app-card--table">
            <div class="connected-app-card__head">
              <div><p class="eyebrow">Transaction logs</p><h3>Authentication and API events</h3></div>
              {{#if ../orgAdmin.canExportConnectedAppLogs}}
                <a class="button button--ghost" href="{{../dashboardBasePath}}/admin/connected-apps/{{id}}/logs.csv" target="_blank" rel="noopener">Export CSV</a>
              {{/if}}
            </div>
            <div class="table-wrap">
              <table class="workspace-table connected-app-subtable">
                <thead><tr><th>Time</th><th>Category</th><th>Event</th><th>Status</th><th>Subject</th></tr></thead>
                <tbody>
                  {{#each modalLogs.rows}}
                    <tr><td>{{createdAt}}</td><td>{{category}}</td><td>{{eventType}}</td><td>{{statusLabel}}</td><td>{{subject}}</td></tr>
                  {{/each}}
                </tbody>
              </table>
              {{#unless modalLogs.hasRows}}<p class="empty-table-note">No connected app events have been recorded yet.</p>{{/unless}}
            </div>
          </article>

          <article class="connected-app-card connected-app-card--table">
            <div class="connected-app-card__head">
              <div><p class="eyebrow">Immutable wallet challenges</p><h3>Wallet decisions</h3></div>
            </div>
            <div class="table-wrap">
              <table class="workspace-table connected-app-subtable">
                <thead><tr><th>Time</th><th>Action</th><th>Subject</th><th>Status</th><th>Resource</th></tr></thead>
                <tbody>
                  {{#each modalWalletChallenges}}
                    <tr><td>{{createdAt}}</td><td>{{action}}</td><td>{{subject}}</td><td>{{status}}</td><td>{{resourceType}} {{resourceId}}</td></tr>
                  {{/each}}
                </tbody>
              </table>
              {{#unless hasModalWalletChallenges}}<p class="empty-table-note">No wallet challenges have been sent by this app yet.</p>{{/unless}}
            </div>
          </article>
        </div>
      </section>
    </div>

    <div class="app-modal" id="modal-connected-app-secret-{{id}}" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="secret-title-{{id}}">
        <div class="app-modal__head">
          <div><p class="eyebrow">Client secret</p><h2 id="secret-title-{{id}}">Create secret for {{name}}</h2><p>Maximum {{maxCredentialCount}} active secrets per registration.</p></div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <form class="wizard-form" method="post" action="{{../dashboardBasePath}}/admin/connected-apps/{{id}}/secrets">
          <div class="field-row">
            <div class="field-group"><label for="secret-label-{{id}}">Label</label><input id="secret-label-{{id}}" name="label" type="text" placeholder="Production secret"></div>
            <div class="field-group"><label for="secret-expiry-{{id}}">Expiry</label><input id="secret-expiry-{{id}}" name="expiresAt" type="date"></div>
          </div>
          <div class="modal-actions">
            <button class="button button--primary button--blue" type="submit">Create secret</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>
    </div>

    <div class="app-modal" id="modal-connected-app-certificate-{{id}}" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel app-modal__panel--wide" role="dialog" aria-modal="true" aria-labelledby="certificate-title-{{id}}">
        <div class="app-modal__head">
          <div><p class="eyebrow">Certificate</p><h2 id="certificate-title-{{id}}">Import certificate for {{name}}</h2><p>Maximum {{maxCredentialCount}} active certificates per registration.</p></div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <form class="wizard-form" method="post" action="{{../dashboardBasePath}}/admin/connected-apps/{{id}}/certificates">
          <div class="field-row">
            <div class="field-group"><label for="cert-label-{{id}}">Label</label><input id="cert-label-{{id}}" name="label" type="text" placeholder="Production signing certificate"></div>
            <div class="field-group"><label for="cert-expiry-{{id}}">Expiry</label><input id="cert-expiry-{{id}}" name="expiresAt" type="date"></div>
          </div>
          <div class="field-group">
            <label for="cert-pem-{{id}}">Certificate PEM</label>
            <textarea id="cert-pem-{{id}}" name="certificatePem" rows="8" placeholder="-----BEGIN CERTIFICATE-----"></textarea>
          </div>
          <div class="modal-actions">
            <button class="button button--primary button--blue" type="submit">Import certificate</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>
    </div>
  {{/each}}
</section>
{{/if}}

<section id="identity-platforms" class="band band--white blade-panel" data-blade-panel="platforms">
  <div class="section-heading">
    <p class="eyebrow">Identity platforms</p>
    <h2>Connect Aegis ID to the platforms and assurance methods this subscriber uses.</h2>
    <p>Use these setup wizards to connect Microsoft Verified ID, YubiKey/passkeys, Keycloak, Okta, or generic OIDC/SAML systems. Start with the platform your pilot will demonstrate first.</p>
  </div>

  <div class="platform-grid">
    {{#each platforms}}
      <article class="platform-card platform-card--{{status}}">
        <div class="platform-card__head">
          <span class="platform-icon">{{icon}}</span>
          <div>
            <span class="track-label">{{family}}</span>
            <h3>{{name}}</h3>
          </div>
        </div>
        <p>{{summary}}</p>
        <div class="progress-bar" aria-label="{{completed}} of {{total}} setup steps complete">
          <span style="width: {{progressPercent}}%"></span>
        </div>
        <div class="platform-card__meta">
          <span>{{statusLabel}}</span>
          <span>{{completed}} / {{total}}</span>
        </div>
        {{#if lastTestResult}}
          <p class="platform-result {{#if lastTestResult.ok}}platform-result--ok{{else}}platform-result--bad{{/if}}">
            {{lastTestResult.title}}
          </p>
        {{/if}}
        <div class="platform-card__actions">
          {{#if ../orgAdmin.canManageIntegrations}}
            <a class="button button--primary" href="{{../dashboardBasePath}}/platforms/{{id}}/setup">Open Wizard</a>
          {{/if}}
          <a class="button button--ghost" href="{{docsUrl}}" target="_blank" rel="noopener">Docs</a>
        </div>
      </article>
    {{/each}}
  </div>
</section>
  </div>
</section>
