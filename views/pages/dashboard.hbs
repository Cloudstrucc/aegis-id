<section class="workspace-blade" data-workspace-blade>
  <header class="workspace-blade__topbar">
    <a class="workspace-blade__product" href="{{organizationsPath}}">
      <span class="workspace-brand-mark">V</span>
      <span>
        <strong>Vanguard Aegis ID</strong>
        <small>Organization workspace</small>
      </span>
    </a>
    <nav aria-label="Workspace shortcuts">
      <a href="#dashboard-overview" data-blade-link="dashboard">Portal</a>
      {{#if orgAdmin.canViewIntegrations}}
        <a href="#identity-platforms" data-blade-link="platforms">Integrations</a>
      {{/if}}
      <a href="#external-wallet-ledger" data-blade-link="ledger">Ledger</a>
    </nav>
    <span class="workspace-blade__avatar">{{#if user.initials}}{{user.initials}}{{else}}FP{{/if}}</span>
  </header>

  <aside class="workspace-blade__rail" aria-label="Global workspace navigation">
    <a href="#dashboard-overview" data-blade-link="dashboard" aria-label="Dashboard">D</a>
    <a href="#credential-admin" data-blade-link="people" aria-label="People">P</a>
    {{#if orgAdmin.canViewIntegrations}}
      <a href="#identity-platforms" data-blade-link="platforms" aria-label="Integrations">I</a>
    {{/if}}
    <a href="#external-wallet-ledger" data-blade-link="ledger" aria-label="Ledger">L</a>
    {{#if orgAdmin.isAdmin}}
      <a href="#workspace-settings" data-blade-link="settings" aria-label="Settings">S</a>
    {{/if}}
  </aside>

  <aside class="workspace-blade__nav" aria-label="{{workspace.organization}} workspace menu">
    <div class="workspace-blade__head">
      <p>Organization</p>
      <h1>{{workspace.organization}}</h1>
      <span>{{#if orgAdmin.viewer.canViewAllCredentials}}Manage people, credentials, roles, claims, integrations, branding, and audit evidence for this workspace.{{else}}Review your credential, consented claims, and wallet evidence for this organization.{{/if}}</span>
      <div class="workspace-blade__org-chip">
        <span>V</span>
        <div>
          <strong>Workspace active</strong>
          <small>{{orgAdmin.viewer.modeLabel}}</small>
        </div>
      </div>
    </div>
    <nav class="workspace-blade__menu">
      {{#each orgAdmin.bladeNavSections}}
        <p class="workspace-blade__section-label">{{label}}</p>
        {{#each items}}
          <a href="{{href}}" data-blade-link="{{key}}">
            <span>{{icon}}</span>
            <strong>{{label}}{{#if statusTone}}<i class="blade-menu-status blade-menu-status--{{statusTone}}" title="{{statusLabel}}"></i>{{/if}}</strong>
            <small>{{description}}</small>
          </a>
        {{/each}}
      {{/each}}
    </nav>
    <article class="workspace-blade__advice">
      <strong>Next best action</strong>
      <span>{{orgAdmin.viewer.nextActionAdvice}}</span>
    </article>
  </aside>

  <div class="workspace-blade__content">
    <section id="dashboard-overview" class="band band--white blade-panel blade-panel--overview" data-blade-panel="dashboard">
      <div class="blade-overview">
        <div>
          <p class="eyebrow">Dashboard</p>
          <h1>Choose a workspace blade.</h1>
          <p>{{#if welcome}}Subscription captured. Start with a focused blade for people, credentials, integrations, and assurance policies.{{else}}This default view stays intentionally light. Use the menu blade or the tiles below to open focused management surfaces for people, credentials, claims, roles, integrations, branding, and audit evidence.{{/if}}</p>
        </div>
      </div>

      {{#if orgAdmin.canManageAdminAssurance}}
        {{#if orgAdmin.adminProfile.showVerificationBanner}}
          <aside class="identity-reminder" data-dismissible-banner="identity-reminder-{{workspace.id}}">
            <span class="platform-icon">ID</span>
            <div>
              <strong>Administrator profile validation due in {{orgAdmin.adminProfile.verificationDaysRemaining}} days</strong>
              <p>Admins can keep working during the grace period, but higher-trust deployments should validate the original subscriber and co-admins.</p>
            </div>
            <div class="identity-reminder__actions">
              <a class="button button--secondary button--dark-text" href="#admin-verification" data-blade-link="admin-verification">Verify</a>
              <button class="button button--secondary button--dark-text" type="button" data-dismiss-banner>Dismiss</button>
            </div>
          </aside>
        {{/if}}
      {{/if}}

      <div class="dashboard-summary dashboard-summary--four">
        <article>
          <span class="metric">{{orgAdmin.activeCount}}</span>
          <p>Active holders</p>
        </article>
        <article>
          <span class="metric">{{orgAdmin.invitedCount}}</span>
          <p>Pending invites</p>
        </article>
        <article>
          <span class="metric">{{orgAdmin.roles.length}}</span>
          <p>Credential roles</p>
        </article>
        <article>
          <span class="metric">{{orgAdmin.events.length}}</span>
          <p>Wallet challenges</p>
        </article>
      </div>

      <div class="blade-action-grid">
        <a class="blade-action-card" href="#credential-admin" data-blade-link="people">
          <span>USR</span>
          <strong>{{#if orgAdmin.viewer.canViewAllCredentials}}People{{else}}My credential{{/if}}</strong>
          <small>{{#if orgAdmin.viewer.canViewAllCredentials}}Add, edit, revoke, and inspect credential holders only.{{else}}See your roles, claims, status, and wallet evidence.{{/if}}</small>
        </a>
        {{#if orgAdmin.canManageCredentials}}
          <a class="blade-action-card" href="#credentials-issuance" data-blade-link="credentials">
            <span>VID</span>
            <strong>Credentials</strong>
            <small>Create issuance invites, show QR codes, copy wallet links, and monitor acceptance status.</small>
          </a>
        {{/if}}
        {{#if orgAdmin.canViewRoles}}
          <a class="blade-action-card" href="#roles-management" data-blade-link="roles">
            <span>RLS</span>
            <strong>Roles</strong>
            <small>Define admin, employee, contractor, approver, and custom privilege sets.</small>
          </a>
        {{/if}}
        {{#if orgAdmin.canViewClaims}}
          <a class="blade-action-card" href="#claims-management" data-blade-link="claims">
            <span>CLM</span>
            <strong>Claims</strong>
            <small>Choose claim definitions, consent requirements, and delta fields.</small>
          </a>
        {{/if}}
        {{#if orgAdmin.canViewOrgChart}}
          <a class="blade-action-card" href="#org-structure" data-blade-link="org-structure">
            <span>ORG</span>
            <strong>Org chart</strong>
            <small>Model divisions, departments, reporting nodes, and default policy assignments.</small>
          </a>
        {{/if}}
        {{#if orgAdmin.canViewIntegrations}}
          <a class="blade-action-card" href="#identity-platforms" data-blade-link="platforms">
            <span>API</span>
            <strong>Integrations</strong>
            <small>Connect Verified ID, YubiKey, OIDC, SAML, Okta, and Keycloak.</small>
          </a>
        {{/if}}
        {{#if orgAdmin.canViewConnectedApps}}
          <a class="blade-action-card" href="#connected-apps" data-blade-link="connected-apps">
            <span>APP</span>
            <strong>Connected apps</strong>
            <small>Register relying parties, configure OIDC/OAuth clients, issue credentials, and audit API activity.</small>
          </a>
        {{/if}}
        {{#if orgAdmin.canViewBranding}}
          <a class="blade-action-card" href="#org-branding" data-blade-link="branding">
            <span>BRD</span>
            <strong>Branding</strong>
            <small>Set logo, palette, and wallet context shown to holders.</small>
          </a>
        {{/if}}
        <a class="blade-action-card" href="#wallet-challenge-events" data-blade-link="wallet-events">
          <span>LOG</span>
          <strong>Wallet events</strong>
          <small>Review immutable challenge evidence for sign-in, approvals, and revocations.</small>
        </a>
      </div>
    </section>

<section id="credential-admin" class="band band--white blade-panel" data-blade-panel="people">
  <div class="section-heading">
    <p class="eyebrow">People</p>
    <h2>{{#if orgAdmin.viewer.canViewAllCredentials}}Manage credential holders.{{else}}Review your organization credential.{{/if}}</h2>
    <p>{{#if orgAdmin.viewer.canViewAllCredentials}}A single pageable directory for invited, active, revoked, and disabled holders. Row clicks open details; row actions handle edit, re-invite, revoke, promote, and challenge.{{else}}Credential holders can see the roles, claims, invitation status, consent scope, and ledger events that apply to them in this organization.{{/if}}</p>
  </div>
  <article class="blade-guidance">
    <strong>What to do here</strong>
    <span>{{#if orgAdmin.canManagePeople}}Add users when you need to issue credentials, re-invite holders when QR links expire, and revoke credentials when someone leaves or changes relationship to the org.{{else}}Use this page to understand what this organization knows about your credential and what claims you have consented to share.{{/if}}</span>
  </article>

  <div class="dashboard-summary dashboard-summary--four">
    <article>
      <span class="metric">{{orgAdmin.activeCount}}</span>
      <p>Active credentials</p>
    </article>
    <article>
      <span class="metric">{{orgAdmin.invitedCount}}</span>
      <p>Invited</p>
    </article>
    <article>
      <span class="metric">{{orgAdmin.revokedCount}}</span>
      <p>Revoked</p>
    </article>
    <article>
      <span class="metric">{{orgAdmin.coAdminCount}}</span>
      <p>Co-admins</p>
    </article>
  </div>

  {{#unless orgAdmin.canViewPeople}}
    <article class="note-panel">
      <strong>{{orgAdmin.viewer.modeLabel}}</strong>
      <span>{{orgAdmin.viewer.nextActionAdvice}}</span>
    </article>
  {{/unless}}

  <div id="people-directory" class="people-directory">
    <div class="people-directory__head">
      <div>
        <p class="eyebrow">People directory</p>
        <h3>Credential holders and invitations</h3>
        <p>{{orgAdmin.peopleTable.pageSummary}} people shown. Invitations default to {{orgAdmin.orgPolicy.inviteTtlLabel}} unless overridden.</p>
      </div>
      <div class="people-directory__tools">
        {{#if orgAdmin.canManagePeople}}
          <button class="button button--primary button--blue" type="button" data-modal-target="#modal-add-user" data-tour-anchor="add-user">Add User</button>
        {{/if}}
        <form class="people-filters" action="{{dashboardBasePath}}" method="get">
          <input name="peopleSearch" type="search" value="{{orgAdmin.peopleTable.search}}" placeholder="Search people, email, role" aria-label="Search people">
          <select name="peopleStatus" aria-label="Filter by status">
            {{#each orgAdmin.peopleTable.statusOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <select name="peopleType" aria-label="Filter by person type">
            {{#each orgAdmin.peopleTable.personTypeOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <select name="peopleDivision" aria-label="Filter by division">
            {{#each orgAdmin.peopleTable.divisionOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <button class="button button--secondary button--dark-text" type="submit">Apply</button>
        </form>
      </div>
    </div>

    <div class="people-table-wrap">
      <table class="people-table" data-tour-anchor="people-table">
        <thead>
          <tr>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.displayName}}">Name</a></th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.holderEmail}}">Email</a></th>
            <th>Type</th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.divisionName}}">Division</a></th>
            <th>Roles</th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.status}}">Status</a></th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.inviteExpiresAt}}">Invite expiry</a></th>
            <th><a href="{{orgAdmin.peopleTable.sortLinks.consent}}">Assurance</a></th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each orgAdmin.peopleTable.rows}}
            <tr id="{{#if isAdminProfile}}admin-profile-row{{else}}credential-{{id}}{{/if}}" data-row-modal="#{{detailModalId}}">
              <td>
                <button class="table-record-button" type="button" data-modal-target="#{{detailModalId}}">
                  <strong>{{displayName}}</strong>
                  {{#if isAdminProfile}}
                    <span class="validated-mark {{#if (eq verification.status "verified")}}validated-mark--ok{{/if}}" title="{{verificationStatusLabel}}">✓</span>
                  {{/if}}
                </button>
              </td>
              <td>{{holderEmail}}</td>
              <td>{{personTypeLabel}}</td>
              <td>{{divisionName}}</td>
              <td>
                <div class="tag-row tag-row--compact">
                  {{#each roleLabels}}
                    <span>{{this}}</span>
                  {{/each}}
                </div>
              </td>
              <td><span class="status-pill status-pill--{{status}}">{{statusLabel}}</span></td>
              <td>
                {{inviteExpiresLabel}}
                {{#if inviteExpired}}
                  <span class="status-pill status-pill--revoked">Expired</span>
                {{/if}}
              </td>
              <td><span class="status-pill status-pill--consent">{{consentStatusLabel}}</span></td>
              <td>
                <div class="row-actions">
                  <button class="icon-button" type="button" title="View details" data-modal-target="#{{detailModalId}}">View</button>
                  {{#if ../orgAdmin.canManagePeople}}
                    {{#if isAdminProfile}}
                      <button class="icon-button" type="button" title="Verify administrator identity" data-modal-target="#admin-identity-verification">Verify</button>
                    {{else}}
                      <button class="icon-button" type="button" title="Edit credential holder" data-modal-target="#{{editModalId}}">Edit</button>
                      <button class="icon-button" type="button" title="Show invite QR and link" data-modal-target="#{{inviteModalId}}">Invite</button>
                      {{#unless (eq status "revoked")}}
                        <button class="icon-button icon-button--danger" type="button" title="Revoke credential" data-modal-target="#{{revokeModalId}}">Revoke</button>
                      {{/unless}}
                    {{/if}}
                  {{/if}}
                </div>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
      {{#if orgAdmin.peopleTable.empty}}
        <p class="empty-table-note">No credential holders match these filters.</p>
      {{/if}}
    </div>
    <div class="people-pagination">
      {{#if orgAdmin.peopleTable.hasPrevious}}
        <a class="button button--secondary button--dark-text" href="{{orgAdmin.peopleTable.previousUrl}}">Previous</a>
      {{/if}}
      <span>Page {{orgAdmin.peopleTable.page}} of {{orgAdmin.peopleTable.pageCount}}</span>
      {{#if orgAdmin.peopleTable.hasNext}}
        <a class="button button--secondary button--dark-text" href="{{orgAdmin.peopleTable.nextUrl}}">Next</a>
      {{/if}}
    </div>
  </div>
</section>

<div class="workspace-modal-stack">
  {{#if orgAdmin.canManageConnectedApps}}
    <div class="app-modal" id="modal-connected-app-create" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel app-modal__panel--xwide" role="dialog" aria-modal="true" aria-labelledby="modal-connected-app-create-title">
        <div class="app-modal__head">
          <div>
            <p class="eyebrow">Connected app</p>
            <h2 id="modal-connected-app-create-title">Register a relying-party application</h2>
            <p>Create an OIDC/OAuth client for a web app, mobile app, API, or automated integration.</p>
          </div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/connected-apps" method="post">
          <div class="field-row">
            <div class="field-group">
              <label for="new-connected-app-name">App name</label>
              <input id="new-connected-app-name" name="name" type="text" placeholder="Business Expenses" required>
            </div>
            <div class="field-group">
              <label for="new-connected-app-type">App type</label>
              <select id="new-connected-app-type" name="appType">
                <option value="web">Web app</option>
                <option value="mobile">Mobile app</option>
                <option value="api">API / daemon</option>
              </select>
            </div>
          </div>
          <div class="field-group">
            <label for="new-connected-app-description">Description</label>
            <textarea id="new-connected-app-description" name="description" rows="3" placeholder="What this relying party does and who owns it."></textarea>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label for="new-connected-app-redirects">Callback URIs</label>
              <textarea id="new-connected-app-redirects" name="redirectUris" rows="4" placeholder="https://app.example.com/callback&#10;http://localhost:4100/auth/callback"></textarea>
            </div>
            <div class="field-group">
              <label for="new-connected-app-origins">Allowed origins</label>
              <textarea id="new-connected-app-origins" name="allowedOrigins" rows="4" placeholder="https://app.example.com"></textarea>
            </div>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label for="new-connected-app-grants">Grant types</label>
              <input id="new-connected-app-grants" name="grantTypes" type="text" value="authorization_code client_credentials">
            </div>
            <div class="field-group">
              <label for="new-connected-app-onboarding">Registration mode</label>
              <select id="new-connected-app-onboarding" name="onboardingMode">
                <option value="invite-only">Invite only</option>
                <option value="open">Open registration</option>
              </select>
            </div>
          </div>
          <div class="button-row">
            <button class="button button--primary button--blue" type="submit">Create registration</button>
            <button class="button button--ghost" type="button" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>
    </div>
  {{/if}}

  {{#if orgAdmin.canManagePeople}}
    <div class="app-modal" id="modal-add-user" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel app-modal__panel--wide" role="dialog" aria-modal="true" aria-labelledby="modal-add-user-title">
        <div class="app-modal__head">
          <div>
            <p class="eyebrow">Issue credential</p>
            <h2 id="modal-add-user-title">Add a user to {{workspace.organization}}</h2>
            <p>The invite defaults to {{orgAdmin.orgPolicy.inviteTtlLabel}}. After the credential is created, the QR and link open automatically.</p>
          </div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/credentials" method="post">
          <div class="field-row">
            <div class="field-group">
              <label class="field-label" for="holderEmail">Holder email <span class="field-tooltip" tabindex="0" data-tooltip="The email address used to identify the wallet holder and send human follow-up.">?</span></label>
              <input id="holderEmail" name="holderEmail" type="email" value="identity@vanguardcs.ca" required>
            </div>
            <div class="field-group">
              <label class="field-label" for="displayName">Display name <span class="field-tooltip" tabindex="0" data-tooltip="The name shown in the admin dashboard and wallet credential profile.">?</span></label>
              <input id="displayName" name="displayName" type="text" value="Vanguard Team Member" required>
            </div>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label for="personType">Person type</label>
              <select id="personType" name="personType">
                {{#each orgAdmin.personTypes}}
                  <option value="{{id}}">{{name}}</option>
                {{/each}}
              </select>
            </div>
            <div class="field-group">
              <label for="divisionId">Division / sub-organization</label>
              <select id="divisionId" name="divisionId">
                {{#each orgAdmin.orgUnitOptions}}
                  <option value="{{id}}">{{indentedName}}</option>
                {{/each}}
              </select>
            </div>
            <div class="field-group">
              <label class="field-label" for="inviteTtlDays">Invite expiry days <span class="field-tooltip" tabindex="0" data-tooltip="Default is 7 days. Use a shorter window for high-risk invites or a longer one for partners who need scheduling time.">?</span></label>
              <input id="inviteTtlDays" name="inviteTtlDays" type="number" min="1" max="365" value="{{orgAdmin.orgPolicy.inviteTtlDays}}">
            </div>
          </div>
          <div>
            <p class="form-note">Roles</p>
            <div class="checkbox-grid">
              {{#each orgAdmin.roles}}
                <label class="checkline">
                  <input type="checkbox" name="roleIds" value="{{id}}">
                  <span>{{name}}</span>
                </label>
              {{/each}}
            </div>
          </div>
          <div>
            <p class="form-note">Claims requested by wallet consent challenge</p>
            <div class="checkbox-grid">
              {{#each orgAdmin.claimConsentOptions}}
                <label class="checkline">
                  <input type="checkbox" name="requestedClaimKeys" value="{{key}}" {{#if checked}}checked{{/if}}>
                  <span>{{label}}</span>
                </label>
              {{/each}}
            </div>
          </div>
          <div class="claim-edit-grid">
            {{#each orgAdmin.claimDefinitions}}
              <div class="field-group">
                <label for="issue-claim-{{key}}">{{label}}</label>
                <input id="issue-claim-{{key}}" name="claim_{{key}}" type="{{type}}" value="{{defaultValue}}">
              </div>
            {{/each}}
          </div>
          <div class="modal-actions">
            <button class="button button--primary button--blue" type="submit">Issue Credential</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </div>
        </form>
      </section>
    </div>

    <div class="app-modal" id="admin-profile-detail" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="admin-profile-title">
        <div class="app-modal__head">
          <div>
            <p class="eyebrow">Original subscriber</p>
            <h2 id="admin-profile-title">{{orgAdmin.adminProfile.displayName}}</h2>
            <p>{{orgAdmin.adminProfile.holderEmail}}</p>
          </div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <dl class="claim-list">
          <div><dt>Role</dt><dd>{{orgAdmin.adminProfile.statusLabel}}</dd></div>
          <div><dt>Organization</dt><dd>{{workspace.organization}}</dd></div>
          <div><dt>Verification</dt><dd>{{orgAdmin.adminProfile.verificationStatusLabel}}</dd></div>
          <div><dt>Deadline</dt><dd>{{orgAdmin.adminProfile.verificationDeadlineLabel}}</dd></div>
          <div><dt>Last validated</dt><dd>{{orgAdmin.adminProfile.lastValidatedLabel}}</dd></div>
          <div><dt>Next validation</dt><dd>{{orgAdmin.adminProfile.nextValidationDueLabel}}</dd></div>
        </dl>
        <div class="modal-actions">
          <button class="button button--primary button--blue" type="button" data-modal-target="#admin-identity-verification">Verify ID</button>
          <button class="button button--secondary button--dark-text" type="button" data-modal-close>Close</button>
        </div>
      </section>
    </div>

    <div class="app-modal" id="admin-identity-verification" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel app-modal__panel--wide" role="dialog" aria-modal="true" aria-labelledby="admin-idv-title">
        <div class="app-modal__head">
          <div>
            <p class="eyebrow">Lab ID verification</p>
            <h2 id="admin-idv-title">Validate administrator profile</h2>
            <p>This pilot uses local open-source face detection for capture readiness and stores only image hashes, score, provider, and status.</p>
          </div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <form class="wizard-form" action="{{dashboardBasePath}}/admin/identity-verification" method="post" data-idv-form>
          <ol class="idv-stepper" aria-label="Administrator identity validation steps">
            <li class="is-active" data-idv-step-indicator="document"><span>1</span> Government ID</li>
            <li data-idv-step-indicator="face"><span>2</span> Live face capture</li>
            <li data-idv-step-indicator="analysis"><span>3</span> Analysis</li>
          </ol>

          <section class="idv-step" data-idv-step="document">
            <div>
              <p class="eyebrow">Step 1</p>
              <h3>Upload a government photo ID.</h3>
              <p class="form-note">Use a clear photo or scan. For this lab, the image is converted in the browser and the server stores a hash only.</p>
            </div>
            <div class="idv-document-grid">
              <div class="field-group">
                <label for="idImageUpload">Government ID image</label>
                <input id="idImageUpload" type="file" accept="image/png,image/jpeg,image/webp" data-image-to-hidden="idImageDataUrl">
                <input type="hidden" name="idImageDataUrl" data-image-hidden="idImageDataUrl">
              </div>
              <div class="idv-preview" data-idv-id-preview>
                <span>ID preview</span>
              </div>
            </div>
            <div class="modal-actions">
              <button class="button button--primary button--blue" type="button" data-idv-next="face" disabled>Continue to Face Capture</button>
              <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
            </div>
          </section>

          <section class="idv-step" data-idv-step="face" hidden>
            <div>
              <p class="eyebrow">Step 2</p>
              <h3>Look into the camera until your face is captured.</h3>
              <p class="form-note">MediaPipe Face Detection runs in the browser. The capture button enables once one face is centered and confidently detected.</p>
            </div>
            <div class="idv-camera-shell">
              <div class="idv-camera-frame" data-idv-camera-frame>
                <video data-idv-video autoplay muted playsinline></video>
                <canvas data-idv-canvas hidden></canvas>
                <div class="idv-face-guide" aria-hidden="true"></div>
                <div class="idv-camera-placeholder" data-idv-camera-placeholder>
                  <strong>Camera not started</strong>
                  <span>Start the camera and keep your face inside the guide.</span>
                </div>
              </div>
              <div class="idv-camera-status" data-idv-status>Waiting for camera permission.</div>
            </div>
            <input type="hidden" name="faceImageDataUrl" data-image-hidden="faceImageDataUrl">
            <input type="hidden" name="faceDetectionScore" data-idv-face-score>
            <input type="hidden" name="faceDetectionProvider" value="mediapipe-face-detection">
            <div class="modal-actions">
              <button class="button button--primary button--blue" type="button" data-idv-start-camera>Start Camera</button>
              <button class="button button--secondary button--dark-text" type="button" data-idv-capture disabled>Capture Face</button>
              <button class="button button--ghost" type="button" data-idv-back="document">Back</button>
            </div>
          </section>

          <section class="idv-step" data-idv-step="analysis" hidden>
            <div>
              <p class="eyebrow">Step 3</p>
              <h3>Review analysis and submit validation.</h3>
              <p class="form-note">The lab adapter compares the captured evidence and records provider metadata, hashes, and a score. Start over if the capture does not look right.</p>
            </div>
            <div class="idv-analysis-grid">
              <div class="idv-preview" data-idv-analysis-id>
                <span>ID evidence ready</span>
              </div>
              <div class="idv-preview" data-idv-analysis-face>
                <span>Face capture ready</span>
              </div>
              <article class="note-panel idv-result-panel">
                <strong data-idv-analysis-title>Ready for local analysis</strong>
                <span data-idv-analysis-copy>Submit when both evidence items look correct, or start over to recapture.</span>
              </article>
            </div>
            <div class="modal-actions">
              <button class="button button--primary button--blue" type="submit" data-idv-submit>Submit Validation</button>
              <button class="button button--secondary button--dark-text" type="button" data-idv-start-over>Start Over</button>
              <button class="button button--ghost" type="button" data-idv-back="face">Back</button>
            </div>
          </section>

          <article class="note-panel">
            <strong>Production note</strong>
            <span>This lab uses Apache-2.0 MediaPipe Face Detection for readiness checks. Use a reviewed IDV workflow and retention policy before processing real identity documents in production.</span>
          </article>
        </form>
      </section>
    </div>
  {{/if}}

  {{#each orgAdmin.credentials}}
    <div class="app-modal" id="{{detailModalId}}" hidden>
      <div class="app-modal__backdrop" data-modal-close></div>
      <section class="app-modal__panel app-modal__panel--wide" role="dialog" aria-modal="true" aria-labelledby="detail-title-{{id}}">
        <div class="app-modal__head">
          <div>
            <p class="eyebrow">{{statusLabel}}</p>
            <h2 id="detail-title-{{id}}">{{displayName}}</h2>
            <p>{{holderEmail}}</p>
          </div>
          <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
        </div>
        <div class="tag-row">
          <span>{{personTypeLabel}}</span>
          <span>{{divisionName}}</span>
          <span>Invite expires {{inviteExpiresLabel}}</span>
          {{#each roleLabels}}<span>{{this}}</span>{{/each}}
          {{#if coAdminStatus}}<span>Co-admin: {{coAdminStatus}}</span>{{/if}}
          <span>{{consentStatusLabel}}</span>
        </div>
        <div class="modal-split">
          <div>
            <h3>Credential profile</h3>
            <dl class="claim-list">
              {{#each claimFields}}
                <div><dt>{{label}}</dt><dd>{{value}}</dd></div>
              {{/each}}
            </dl>
          </div>
          <div>
            <h3>Consent-scoped claims</h3>
            <div class="tag-row">
              {{#each requestedClaimLabels}}<span>Requested: {{this}}</span>{{/each}}
              {{#each deltaClaimLabels}}<span>Delta supplied: {{this}}</span>{{/each}}
            </div>
            {{#if sharedClaimFields}}
              <dl class="claim-list">
                {{#each sharedClaimFields}}
                  <div><dt>{{label}}</dt><dd>{{value}}</dd></div>
                {{/each}}
              </dl>
            {{/if}}
          </div>
        </div>
        <section class="credential-invite-viewer" aria-label="Credential invitation">
          <div class="credential-invite-viewer__head">
            <div>
              <p class="eyebrow">Wallet invitation</p>
              <h3>Scan or inspect the credential invite</h3>
            </div>
            <div class="credential-invite-switch" role="tablist" aria-label="Invitation view">
              <input type="radio" name="credential-invite-view-{{id}}" id="credential-invite-qr-{{id}}" checked>
              <label for="credential-invite-qr-{{id}}">QR</label>
              <input type="radio" name="credential-invite-view-{{id}}" id="credential-invite-json-{{id}}">
              <label for="credential-invite-json-{{id}}">JSON</label>
            </div>
          </div>
          <div class="credential-invite-panel credential-invite-panel--qr">
            <img src="{{inviteQrCodeDataUrl}}" alt="{{displayName}} wallet invitation QR code">
            <div>
              <strong>Credential invite link</strong>
              <p>Use this if the holder registered in the web app but still needs to add the credential to the Vanguard Aegis ID wallet.</p>
              <code>{{inviteUrl}}</code>
              <a class="button button--secondary button--dark-text" href="{{webInviteUrl}}" target="_blank" rel="noopener">Open wallet invite page</a>
            </div>
          </div>
          <div class="credential-invite-panel credential-invite-panel--json">
            <pre>{{invitePayloadJson}}</pre>
          </div>
        </section>
        <div class="event-list event-list--compact">
          {{#each events}}
            <details>
              <summary>{{title}} <span>{{createdAt}}</span></summary>
              <pre>{{details}}</pre>
            </details>
          {{/each}}
        </div>
        {{#if ../orgAdmin.canManagePeople}}
          <div class="modal-actions">
            <button class="button button--primary button--blue" type="button" data-modal-target="#{{editModalId}}">Edit</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-target="#{{inviteModalId}}">Invite QR</button>
            {{#if (eq status "invited")}}
              <form action="{{../dashboardBasePath}}/admin/credentials/{{id}}/accept" method="post">
                <button class="button button--secondary button--dark-text" type="submit">Mark Accepted</button>
              </form>
            {{/if}}
            {{#if (eq status "active")}}
              {{#if coAdminRequestId}}
                <form action="{{../dashboardBasePath}}/admin/co-admin/{{coAdminRequestId}}/admin/accept" method="post">
                  <button class="button button--secondary button--dark-text" type="submit">Accept Admin Challenge</button>
                </form>
                <form action="{{../dashboardBasePath}}/admin/co-admin/{{coAdminRequestId}}/holder/accept" method="post">
                  <button class="button button--secondary button--dark-text" type="submit">Accept Holder Challenge</button>
                </form>
                <form action="{{../dashboardBasePath}}/admin/credentials/{{id}}/co-admin/revoke" method="post">
                  <button class="button button--ghost" type="submit">Revoke Co-admin</button>
                </form>
              {{else}}
                <form action="{{../dashboardBasePath}}/admin/credentials/{{id}}/co-admin/request" method="post">
                  <button class="button button--secondary button--dark-text" type="submit">Promote to Co-admin</button>
                </form>
              {{/if}}
            {{/if}}
            {{#unless (eq status "revoked")}}
              <button class="button button--ghost" type="button" data-modal-target="#{{revokeModalId}}">Revoke</button>
            {{/unless}}
          </div>
        {{/if}}
      </section>
    </div>

    {{#if ../orgAdmin.canManagePeople}}
      <div class="app-modal" id="{{editModalId}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel app-modal__panel--wide" role="dialog" aria-modal="true" aria-labelledby="edit-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">Edit credential</p>
              <h2 id="edit-title-{{id}}">{{displayName}}</h2>
              <p>Update holder profile, roles, claims, and consent request scope.</p>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>
          <form class="wizard-form" action="{{../dashboardBasePath}}/admin/credentials/{{id}}/update" method="post">
            <div class="field-row">
              <div class="field-group">
                <label for="holder-{{id}}">Holder email</label>
                <input id="holder-{{id}}" name="holderEmail" type="email" value="{{holderEmail}}">
              </div>
              <div class="field-group">
                <label for="name-{{id}}">Display name</label>
                <input id="name-{{id}}" name="displayName" type="text" value="{{displayName}}">
              </div>
              <div class="field-group">
                <label for="type-{{id}}">Person type</label>
                <select id="type-{{id}}" name="personType">
                  {{#each personTypeOptions}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                  {{/each}}
                </select>
              </div>
              <div class="field-group">
                <label for="division-{{id}}">Division</label>
                <select id="division-{{id}}" name="divisionId">
                  {{#each divisionOptions}}
                    <option value="{{id}}" {{#if selected}}selected{{/if}}>{{indentedName}}</option>
                  {{/each}}
                </select>
              </div>
              <div class="field-group">
                <label for="ttl-{{id}}">Invite expiry days</label>
                <input id="ttl-{{id}}" name="inviteTtlDays" type="number" min="1" max="365" value="{{inviteTtlDays}}">
              </div>
            </div>
            <div>
              <p class="form-note">Roles</p>
              <div class="checkbox-grid">
                {{#each availableRoles}}
                  <label class="checkline">
                    <input type="checkbox" name="roleIds" value="{{id}}" {{#if checked}}checked{{/if}}>
                    <span>{{name}}</span>
                  </label>
                {{/each}}
              </div>
            </div>
            <div class="claim-edit-grid">
              {{#each claimFields}}
                <div class="field-group">
                  <label for="credential-{{../id}}-{{key}}">{{label}}</label>
                  <input id="credential-{{../id}}-{{key}}" name="claim_{{key}}" type="{{type}}" value="{{value}}">
                </div>
              {{/each}}
            </div>
            <div>
              <p class="form-note">Claims to request by wallet consent challenge</p>
              <div class="checkbox-grid">
                {{#each consentClaimFields}}
                  <label class="checkline">
                    <input type="checkbox" name="requestedClaimKeys" value="{{key}}" {{#if checked}}checked{{/if}}>
                    <span>{{label}}</span>
                  </label>
                {{/each}}
              </div>
            </div>
            <div class="modal-actions">
              <button class="button button--primary button--blue" type="submit">Save Changes</button>
              <button class="button button--secondary button--dark-text" type="button" data-modal-target="#credential-reset-validation-{{id}}">Reset Profile Validation</button>
              <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
            </div>
          </form>
        </section>
      </div>

      <div class="app-modal" id="credential-reset-validation-{{id}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="credential-reset-validation-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">Danger action</p>
              <h2 id="credential-reset-validation-title-{{id}}">Reset validation for {{displayName}}?</h2>
              <p>This sends an administrative wallet challenge and clears the current validation state for this profile. The user will need to complete validation again.</p>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>
          <form class="modal-actions" action="{{../dashboardBasePath}}/admin/credentials/{{id}}/reset-validation" method="post">
            <button class="button button--ghost" type="submit">Reset Validation</button>
            <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
          </form>
        </section>
      </div>

      <div class="app-modal" id="{{inviteModalId}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="invite-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">Wallet invite</p>
              <h2 id="invite-title-{{id}}">Invite {{displayName}}</h2>
              <p>Send this QR or copyable link to the holder. Expiry: {{inviteExpiresLabel}}.</p>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>
          <article class="demo-qr-card">
            <img class="demo-qr-card__image" src="{{inviteQrCodeDataUrl}}" alt="{{displayName}} credential invitation QR code">
            <code class="demo-qr-card__url">{{inviteUrl}}</code>
            <button class="button button--secondary button--dark-text demo-qr-card__copy" type="button" data-copy-value="{{inviteUrl}}">Copy invite link</button>
            <details class="demo-qr-card__details">
              <summary>Web fallback link</summary>
              <code class="demo-qr-card__url">{{webInviteUrl}}</code>
              <button class="button button--secondary button--dark-text demo-qr-card__copy" type="button" data-copy-value="{{webInviteUrl}}">Copy web link</button>
            </details>
          </article>
          <form class="wizard-form" action="{{../dashboardBasePath}}/admin/credentials/{{id}}/reinvite" method="post">
            <div class="field-group">
              <label for="reinvite-ttl-{{id}}">Reset invite expiry days</label>
              <input id="reinvite-ttl-{{id}}" name="inviteTtlDays" type="number" min="1" max="365" value="{{inviteTtlDays}}">
            </div>
            <div class="modal-actions">
              <button class="button button--primary button--blue" type="submit">Re-issue Invite</button>
              <button class="button button--secondary button--dark-text" type="button" data-modal-close>Close</button>
            </div>
          </form>
        </section>
      </div>

      <div class="app-modal" id="{{revokeModalId}}" hidden>
        <div class="app-modal__backdrop" data-modal-close></div>
        <section class="app-modal__panel" role="dialog" aria-modal="true" aria-labelledby="revoke-title-{{id}}">
          <div class="app-modal__head">
            <div>
              <p class="eyebrow">Confirm revocation</p>
              <h2 id="revoke-title-{{id}}">Revoke {{displayName}}?</h2>
              <p>The credential will show disabled in the wallet organization context and remain in audit history.</p>
            </div>
            <button class="video-modal__close" type="button" data-modal-close aria-label="Close">×</button>
          </div>
          <form class="wizard-form" action="{{../dashboardBasePath}}/admin/credentials/{{id}}/revoke" method="post">
            <div class="field-group">
              <label for="revoke-reason-{{id}}">Revocation reason</label>
              <input id="revoke-reason-{{id}}" name="reason" type="text" placeholder="Employment ended, duplicate invite, role changed">
            </div>
            <div class="modal-actions">
              <button class="button button--ghost" type="submit">Revoke Credential</button>
              <button class="button button--secondary button--dark-text" type="button" data-modal-close>Cancel</button>
            </div>
          </form>
        </section>
      </div>
    {{/if}}
  {{/each}}
</div>

