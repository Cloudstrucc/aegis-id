<section class="page-hero page-hero--compact mock-wallet-hero">
  <div class="mock-wallet-layout">
    <div class="mock-wallet-copy">
      <p class="eyebrow">Wallet invitation</p>
      <h1>{{invite.organizationName}} credential invite.</h1>
      <p>Open this invite in the Vanguard Aegis ID wallet, or scan the QR code from another device.</p>
      <div class="hero__actions">
        <a class="button button--primary" href="{{invite.inviteUrl}}">Open Wallet</a>
        <button class="button button--secondary" type="button" data-copy-value="{{invite.inviteUrl}}">Copy Invite Link</button>
      </div>
      <div class="note-panel note-panel--portal">
        <strong>Also use the web portal</strong>
        <span>Create or sign in with {{invite.holderEmail}} to see this organization in your Organizations page. Wallet acceptance activates the credential.</span>
        <div class="button-row">
          <a class="button button--blue" href="{{invite.portalRegisterUrl}}">Create portal account</a>
          <a class="button button--ghost" href="{{invite.portalLoginUrl}}">Sign in</a>
        </div>
      </div>
    </div>

    <aside class="wallet-qr-card" aria-label="Scannable credential invitation QR code">
      <div class="wallet-qr-card__head">
        <span class="wallet-qr-card__icon" aria-hidden="true">QR</span>
        <div>
          <p class="eyebrow">Credential holder</p>
          <h2>{{invite.displayName}}</h2>
        </div>
      </div>
      <img class="wallet-qr-card__image" src="{{invite.inviteQrCodeDataUrl}}" alt="{{invite.displayName}} credential invitation QR code">
      <p class="wallet-qr-card__hint">{{invite.holderEmail}} · expires {{invite.inviteExpiresLabel}}</p>
      {{#if invite.inviteExpired}}
        <p class="demo-qr-card__warning">This invitation has expired. Ask an administrator to re-issue it.</p>
      {{/if}}
      <code class="wallet-qr-card__url">{{invite.inviteUrl}}</code>
    </aside>
  </div>
</section>
